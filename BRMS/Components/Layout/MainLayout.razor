@inherits LayoutComponentBase

<div class="main-layout-shell">
    <aside class="main-layout-sidebar">
        <Sidebar />
    </aside>

    <header class="main-layout-topbar">
        <TopBar />
    </header>

    <main class="main-layout-content">
        @Body
    </main>
</div>

<style>
    .main-layout-shell {
        min-height: 100vh;
        background: #F8F9FA;
    }

    .main-layout-sidebar {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: 220px;
        background: #1E293B;
        border-right: 1px solid #243244;
        z-index: 20;
    }

    .main-layout-topbar {
        position: fixed;
        top: 0;
        left: 220px;
        right: 0;
        height: 56px;
        background: #FFFFFF;
        border-bottom: 1px solid #E2E8F0;
        z-index: 15;
    }

    .main-layout-content {
        min-height: 100vh;
        margin-left: 220px;
        padding: 80px 24px 24px;
        background: #F8F9FA;
    }

    @@media (max-width: 900px) {
        .main-layout-sidebar {
            position: relative;
            width: 100%;
            height: auto;
        }

        .main-layout-topbar {
            position: relative;
            left: 0;
        }

        .main-layout-content {
            margin-left: 0;
            padding: 24px;
        }
    }
</style>
