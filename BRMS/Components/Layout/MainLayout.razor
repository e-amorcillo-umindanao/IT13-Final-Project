@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject SessionHelper SessionHelper
@implements IDisposable

<div class="main-layout-shell"
     tabindex="0"
     @onclick="@(_ => ResetSessionTimer())"
     @onmousemove="@(_ => ResetSessionTimer())"
     @onmousedown="@(_ => ResetSessionTimer())"
     @onkeydown="@(_ => ResetSessionTimer())">
    <aside class="main-layout-sidebar">
        <Sidebar />
    </aside>

    <header class="main-layout-topbar">
        <TopBar />
    </header>

    <main class="main-layout-content">
        @Body
    </main>
</div>

@code {
    private Timer? _sessionCheckTimer;
    private bool _isCheckingSession;

    protected override void OnInitialized()
    {
        SessionHelper.ResetTimer();
        NavigationManager.LocationChanged += HandleLocationChanged;
        AuthService.AuthStateChanged += HandleAuthStateChanged;
        _sessionCheckTimer = new Timer(_ => _ = CheckSessionExpirationAsync(), null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        ResetSessionTimer();
    }

    private void HandleAuthStateChanged()
    {
        if (AuthService.IsAuthenticated)
        {
            ResetSessionTimer();
        }
    }

    private void ResetSessionTimer()
    {
        SessionHelper.ResetTimer();
    }

    private async Task CheckSessionExpirationAsync()
    {
        if (_isCheckingSession || !AuthService.IsAuthenticated || !SessionHelper.IsSessionExpired())
        {
            return;
        }

        _isCheckingSession = true;

        try
        {
            await InvokeAsync(async () =>
            {
                if (!AuthService.IsAuthenticated || !SessionHelper.IsSessionExpired())
                {
                    return;
                }

                await AuthService.LogoutAsync("Session expired after 15 minutes of inactivity.");
                NavigationManager.NavigateTo("/login", false);
            });
        }
        finally
        {
            _isCheckingSession = false;
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
        AuthService.AuthStateChanged -= HandleAuthStateChanged;
        _sessionCheckTimer?.Dispose();
    }
}

<style>
    .main-layout-shell {
        min-height: 100vh;
        background: #F8F9FA;
        outline: none;
    }

    .main-layout-sidebar {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: 220px;
        background: #1E293B;
        border-right: 1px solid #243244;
        z-index: 20;
    }

    .main-layout-topbar {
        position: fixed;
        top: 0;
        left: 220px;
        right: 0;
        height: 56px;
        background: #FFFFFF;
        border-bottom: 1px solid #E2E8F0;
        z-index: 15;
    }

    .main-layout-content {
        min-height: 100vh;
        margin-left: 220px;
        padding: 80px 24px 24px;
        background: #F8F9FA;
    }

    @@media (max-width: 900px) {
        .main-layout-sidebar {
            position: relative;
            width: 100%;
            height: auto;
        }

        .main-layout-topbar {
            position: relative;
            left: 0;
        }

        .main-layout-content {
            margin-left: 0;
            padding: 24px;
        }
    }
</style>
