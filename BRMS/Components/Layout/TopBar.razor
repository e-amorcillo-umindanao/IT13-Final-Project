@inject AuthService AuthService
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="topbar-shell">
    <div class="topbar-brand">BRMS</div>
    <div class="topbar-title">Barangay Catalunan Pequeno</div>
    <div class="topbar-user">
        <div class="topbar-user-menu-shell">
            <MudButton Variant="Variant.Text"
                       Style="color: #1E293B; font-weight: 500; text-transform: none; border-radius: 4px;"
                       OnClick="ToggleUserMenu">
                @CurrentUsername @((MarkupString)"&#9662;")
            </MudButton>

            @if (_userMenuOpen)
            {
                <MudPaper Elevation="0"
                          Class="topbar-user-menu"
                          Style="border: 1px solid #E2E8F0; border-radius: 4px; background: #FFFFFF;">
                    <MudButton Variant="Variant.Text"
                               FullWidth="true"
                               Style="justify-content: flex-start; color: #1E293B; text-transform: none; border-radius: 4px;"
                               OnClick="HandleLogoutAsync">
                        Logout
                    </MudButton>
                </MudPaper>
            }
        </div>
    </div>
</div>

@code {
    private User? currentUser => AuthService.CurrentUser;
    private string CurrentUsername => currentUser?.Username ?? "Guest";
    private bool _userMenuOpen;

    protected override void OnInitialized()
    {
        AuthService.AuthStateChanged += HandleAuthStateChanged;
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void ToggleUserMenu()
    {
        _userMenuOpen = !_userMenuOpen;
    }

    private void HandleAuthStateChanged()
    {
        _userMenuOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _userMenuOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task HandleLogoutAsync()
    {
        _userMenuOpen = false;
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login", false);
    }

    public void Dispose()
    {
        AuthService.AuthStateChanged -= HandleAuthStateChanged;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}

<style>
    .topbar-shell {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        height: 100%;
        padding: 0 20px;
        gap: 16px;
        background: #FFFFFF;
    }

    .topbar-brand {
        justify-self: start;
        font-size: 18px;
        font-weight: 700;
        color: #0F172A;
    }

    .topbar-title {
        justify-self: center;
        font-size: 14px;
        font-weight: 600;
        color: #334155;
        white-space: nowrap;
    }

    .topbar-user {
        justify-self: end;
    }

    .topbar-user-menu-shell {
        position: relative;
    }

    .topbar-user-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        min-width: 140px;
        padding: 6px;
        z-index: 100;
    }

    @@media (max-width: 900px) {
        .topbar-shell {
            grid-template-columns: 1fr auto;
        }

        .topbar-title {
            display: none;
        }
    }
</style>
