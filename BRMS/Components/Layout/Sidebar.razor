@inject AuthService AuthService
@implements IDisposable

<div class="sidebar-shell">
    <div class="sidebar-brand">BRMS</div>

    <nav class="sidebar-nav">
        @if (CanViewDashboard)
        {
            <NavLink href="/dashboard" Match="NavLinkMatch.All" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.SpaceDashboard" Size="Size.Medium" />
                <span>Dashboard</span>
            </NavLink>
        }

        @if (CanViewProfile)
        {
            <NavLink href="/profile" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Medium" />
                <span>Profile</span>
            </NavLink>
        }

        @if (CanViewResidents)
        {
            <NavLink href="/residents" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Size="Size.Medium" />
                <span>Residents</span>
            </NavLink>
        }

        @if (CanViewHouseholds)
        {
            <NavLink href="/households" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.HomeWork" Size="Size.Medium" />
                <span>Households</span>
            </NavLink>
        }

        @if (CanViewEngagement)
        {
            <NavLink href="/engagement" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.Handshake" Size="Size.Medium" />
                <span>Engagement</span>
            </NavLink>
        }

        @if (CanViewEvents)
        {
            <NavLink href="/events" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Medium" />
                <span>Events</span>
            </NavLink>
        }

        @if (CanViewBlotter)
        {
            <NavLink href="/blotter" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.Gavel" Size="Size.Medium" />
                <span>Blotter</span>
            </NavLink>
        }

        @if (CanViewClearance)
        {
            <NavLink href="/clearance" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Size="Size.Medium" />
                <span>Clearance</span>
            </NavLink>
        }

        @if (CanViewDocuments)
        {
            <NavLink href="/documents" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Medium" />
                <span>Documents</span>
            </NavLink>
        }

        @if (CanViewReports)
        {
            <NavLink href="/reports" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Medium" />
                <span>Reports</span>
            </NavLink>
        }

        @if (CanViewSettings)
        {
            <NavLink href="/settings" Match="NavLinkMatch.Prefix" class="sidebar-link">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Medium" />
                <span>Settings</span>
            </NavLink>
        }
    </nav>
</div>

@code {
    private string CurrentRole => AuthService.GetCurrentRole();

    private bool CanViewDashboard => IsInRole("Captain", "Kagawad", "Staff", "Resident");
    private bool CanViewProfile => IsInRole("Resident");
    private bool CanViewResidents => IsInRole("Captain", "Kagawad", "Staff");
    private bool CanViewHouseholds => IsInRole("Captain", "Kagawad", "Staff");
    private bool CanViewEngagement => IsInRole("Captain", "Kagawad");
    private bool CanViewEvents => IsInRole("Captain", "Kagawad", "Staff");
    private bool CanViewBlotter => IsInRole("Captain", "Kagawad");
    private bool CanViewClearance => IsInRole("Captain", "Kagawad", "Staff", "Resident");
    private bool CanViewDocuments => IsInRole("Captain", "Kagawad", "Staff");
    private bool CanViewReports => IsInRole("Captain", "Kagawad", "Staff");
    private bool CanViewSettings => IsInRole("Captain");

    protected override void OnInitialized()
    {
        AuthService.AuthStateChanged += HandleAuthStateChanged;
    }

    private bool IsInRole(params string[] allowedRoles)
    {
        return allowedRoles.Any(role =>
            string.Equals(CurrentRole, role, StringComparison.OrdinalIgnoreCase));
    }

    private void HandleAuthStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthService.AuthStateChanged -= HandleAuthStateChanged;
    }
}

<style>
    .sidebar-shell {
        display: flex;
        flex-direction: column;
        gap: 24px;
        height: 100%;
        padding: 20px 16px;
        background: #1E293B;
    }

    .sidebar-brand {
        color: #FFFFFF;
        font-size: 20px;
        font-weight: 700;
        letter-spacing: 0.04em;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 4px;
        color: #94A3B8;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: background-color 0.15s ease, color 0.15s ease;
    }

    .sidebar-link .mud-icon-root {
        color: #94A3B8 !important;
    }

    .sidebar-link:hover {
        background: rgba(59, 91, 219, 0.16);
        color: #FFFFFF;
    }

    .sidebar-link:hover .mud-icon-root,
    .sidebar-link.active .mud-icon-root {
        color: #FFFFFF !important;
    }

    .sidebar-link.active {
        background: #3B5BDB;
        color: #FFFFFF;
    }
</style>
