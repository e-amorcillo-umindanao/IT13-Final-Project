@using BRMS.Components.Pages.Auth
@inject NavigationManager NavigationManager
@inject AuthService AuthService
@implements IDisposable

<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@ResolveLayout(routeData)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@(AuthService.IsAuthenticated ? typeof(MainLayout) : typeof(AuthLayout))">
            <div class="page-shell">
                <h1 class="page-title">Page Not Found</h1>
                <MudPaper Class="page-card" Elevation="0">
                    <MudText Typo="Typo.body1">The page you requested does not exist in this Phase 1 scaffold.</MudText>
                </MudPaper>
            </div>
        </LayoutView>
    </NotFound>
</Router>

@code {
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        AuthService.AuthStateChanged += HandleAuthStateChanged;
        GuardRoute();
    }

    private Type ResolveLayout(RouteData routeData)
    {
        return routeData.PageType == typeof(Login) ? typeof(AuthLayout) : typeof(MainLayout);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        GuardRoute();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleAuthStateChanged()
    {
        GuardRoute();
        _ = InvokeAsync(StateHasChanged);
    }

    private void GuardRoute()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');
        var isAuthPath = string.IsNullOrWhiteSpace(relativePath) || string.Equals(relativePath, "login", StringComparison.OrdinalIgnoreCase);

        if (!isAuthPath && !AuthService.IsAuthenticated)
        {
            NavigateIfNeeded("/login", relativePath);
            return;
        }

        if (isAuthPath && AuthService.IsAuthenticated)
        {
            NavigateIfNeeded("/dashboard", relativePath);
            return;
        }

        if (!isAuthPath && AuthService.IsAuthenticated && !CanAccessPath(relativePath))
        {
            NavigateIfNeeded(GetDefaultRouteForCurrentUser(), relativePath);
        }
    }

    private bool CanAccessPath(string relativePath)
    {
        var normalizedPath = relativePath.Trim('/');
        if (string.IsNullOrWhiteSpace(normalizedPath) || string.Equals(normalizedPath, "login", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var segment = normalizedPath
            .Split('/', StringSplitOptions.RemoveEmptyEntries)
            .FirstOrDefault()?
            .ToLowerInvariant();

        return segment switch
        {
            "dashboard" => IsInRole("Captain", "Kagawad", "Staff", "Resident"),
            "profile" => IsInRole("Resident"),
            "residents" => IsInRole("Captain", "Kagawad", "Staff"),
            "households" => IsInRole("Captain", "Kagawad", "Staff"),
            "engagement" => IsInRole("Captain", "Kagawad"),
            "events" => IsInRole("Captain", "Kagawad", "Staff"),
            "blotter" => IsInRole("Captain", "Kagawad"),
            "clearance" => CanAccessClearancePath(normalizedPath),
            "documents" => IsInRole("Captain", "Kagawad", "Staff"),
            "reports" => IsInRole("Captain", "Kagawad", "Staff"),
            "settings" => IsInRole("Captain"),
            _ => true
        };
    }

    private bool CanAccessClearancePath(string normalizedPath)
    {
        if (IsInRole("Captain", "Kagawad", "Staff"))
        {
            return true;
        }

        return IsInRole("Resident") &&
               string.Equals(normalizedPath, "clearance", StringComparison.OrdinalIgnoreCase);
    }

    private string GetDefaultRouteForCurrentUser()
    {
        return IsInRole("Resident") ? "/profile" : "/dashboard";
    }

    private bool IsInRole(params string[] allowedRoles)
    {
        var currentRole = AuthService.GetCurrentRole();
        return allowedRoles.Any(role =>
            string.Equals(currentRole, role, StringComparison.OrdinalIgnoreCase));
    }

    private void NavigateIfNeeded(string targetPath, string currentRelativePath)
    {
        var normalizedCurrentPath = currentRelativePath.Trim('/');
        var normalizedTargetPath = targetPath.Trim('/');

        if (string.Equals(normalizedCurrentPath, normalizedTargetPath, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        NavigationManager.NavigateTo(targetPath, false);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
        AuthService.AuthStateChanged -= HandleAuthStateChanged;
    }
}
