@page "/"
@page "/login"
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<div class="login-page">
    <MudPaper Class="login-card" Elevation="0">
        <MudText Class="login-title">BRMS</MudText>
        <MudText Class="login-subtitle">Barangay Resident Management System</MudText>

        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />

            <div class="login-form">
                <MudTextField @bind-Value="_model.Username"
                              For="@(() => _model.Username)"
                              Placeholder="Username"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Immediate="true" />

                <MudTextField @bind-Value="_model.Password"
                              For="@(() => _model.Password)"
                              Placeholder="Password"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Immediate="true"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                              OnAdornmentClick="TogglePasswordVisibility" />

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="login-alert">
                        @_errorMessage
                    </MudAlert>
                }

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Disabled="@_isSubmitting"
                           Class="login-button">
                    LOGIN
                </MudButton>
            </div>
        </EditForm>

        <MudText Class="login-footer">&#169; Barangay Catalunan Peque&#241;o</MudText>
    </MudPaper>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private bool _showPassword;
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/dashboard", false);
        }
    }

    private async Task HandleLoginAsync()
    {
        if (_isSubmitting)
        {
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        var user = await AuthService.LoginAsync(_model.Username, _model.Password);
        if (user is null)
        {
            _errorMessage = "Invalid username or password.";
            _isSubmitting = false;
            return;
        }

        _isSubmitting = false;
        NavigationManager.NavigateTo("/dashboard", false);
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private sealed class LoginFormModel
    {
        [Required]
        public string Username { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;
    }
}

<style>
    .login-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 24px;
        background: #F8F9FA;
    }

    .login-card {
        width: 100%;
        max-width: 400px;
        padding: 40px;
        border: 1px solid #E2E8F0;
        border-radius: 4px;
        background: #FFFFFF;
        box-shadow: none;
    }

    .login-title {
        margin: 0 0 4px;
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.2;
        color: #1E293B;
    }

    .login-subtitle {
        margin: 0 0 24px;
        font-size: 0.9rem;
        color: #64748B;
    }

    .login-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .login-alert {
        margin: 0;
    }

    .login-button {
        height: 48px;
        border-radius: 4px;
        font-weight: 700;
        color: #FFFFFF;
        background: #3B5BDB;
        box-shadow: none;
    }

    .login-button:hover,
    .login-button:focus-visible {
        background: #3B5BDB;
        box-shadow: none;
    }

    .login-footer {
        display: block;
        margin-top: 24px;
        text-align: center;
        color: #94A3B8;
        font-size: 0.75rem;
    }
</style>
