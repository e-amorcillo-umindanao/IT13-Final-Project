@page "/settings"
@using AuditLogModel = BRMS.Models.AuditLog
@using Microsoft.AspNetCore.Components.Web
@inject AppDbContext DbContext
@inject AuthService AuthService
@inject AuditService AuditService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Settings</PageTitle>

@if (_isAuthorized)
{
    <div class="settings-page">
        <div class="settings-header">
            <h1 class="settings-title">Settings</h1>
        </div>

        @if (_isLoading)
        {
            <MudCard Elevation="0" Style="border:1px solid #E2E8F0; border-radius:4px; padding:24px; background:#FFFFFF;">
                <div class="settings-loading">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </div>
            </MudCard>
        }
        else
        {
            <MudTabs Class="settings-tabs"
                     Style="border-bottom:1px solid #E2E8F0; margin-bottom:24px">
                <MudTabPanel Text="BARANGAY INFO">
                    <MudCard Elevation="0"
                             Style="border:1px solid #E2E8F0; border-radius:4px; padding:24px; background:#FFFFFF;">
                        <EditForm Model="_settingsModel" OnValidSubmit="SaveSettingsAsync">
                            <DataAnnotationsValidator />

                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  @bind-Value="_settingsModel.BarangayName"
                                                  For="@(() => _settingsModel.BarangayName)"
                                                  Label="Barangay Name"
                                                  Variant="Variant.Outlined"
                                                  Style="border-radius:4px"
                                                  FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  @bind-Value="_settingsModel.Municipality"
                                                  For="@(() => _settingsModel.Municipality)"
                                                  Label="Municipality"
                                                  Variant="Variant.Outlined"
                                                  Style="border-radius:4px"
                                                  FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  @bind-Value="_settingsModel.Province"
                                                  For="@(() => _settingsModel.Province)"
                                                  Label="Province"
                                                  Variant="Variant.Outlined"
                                                  Style="border-radius:4px"
                                                  FullWidth="true" />
                                </MudItem>

                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  @bind-Value="_settingsModel.CaptainName"
                                                  Label="Captain Name"
                                                  Variant="Variant.Outlined"
                                                  Style="border-radius:4px"
                                                  FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  @bind-Value="_settingsModel.SecretaryName"
                                                  Label="Secretary Name"
                                                  Variant="Variant.Outlined"
                                                  Style="border-radius:4px"
                                                  FullWidth="true" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField T="string"
                                                  @bind-Value="_settingsModel.ContactNumber"
                                                  Label="Contact Number"
                                                  Variant="Variant.Outlined"
                                                  Style="border-radius:4px"
                                                  FullWidth="true" />
                                </MudItem>

                                <MudItem xs="12">
                                    <MudTextField T="string"
                                                  @bind-Value="_settingsModel.LogoPath"
                                                  Label="Logo Path"
                                                  Variant="Variant.Outlined"
                                                  Style="border-radius:4px"
                                                  FullWidth="true" />
                                </MudItem>
                            </MudGrid>

                            <div class="settings-actions settings-actions-right">
                                <MudButton ButtonType="ButtonType.Submit"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Style="border-radius:4px"
                                           Disabled="_isSavingSettings">
                                    Save Changes
                                </MudButton>
                            </div>
                        </EditForm>
                    </MudCard>
                </MudTabPanel>

                <MudTabPanel Text="USER MANAGEMENT">
                    <div class="settings-section-header">
                        <div class="settings-section-title">User Management</div>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Style="border-radius:4px"
                                   OnClick="OpenAddUserDialog">
                            Add User
                        </MudButton>
                    </div>

                    <MudTable T="User"
                              Items="_users"
                              Elevation="0"
                              Striped="false"
                              Hover="true"
                              RowStyle="height:52px"
                              RowsPerPage="10"
                              Loading="_isLoadingUsers"
                              Style="border:1px solid #E2E8F0; border-radius:4px; background:#FFFFFF;">
                        <HeaderContent>
                            <MudTh>USERNAME</MudTh>
                            <MudTh>ROLE</MudTh>
                            <MudTh>LINKED RESIDENT</MudTh>
                            <MudTh>ACTIVE</MudTh>
                            <MudTh>LAST LOGIN</MudTh>
                            <MudTh>ACTIONS</MudTh>
                        </HeaderContent>

                        <RowTemplate Context="user">
                            <MudTd DataLabel="USERNAME" Class="settings-cell-strong">@user.Username</MudTd>
                            <MudTd DataLabel="ROLE" Class="settings-cell-dark">@(user.Role?.RoleName ?? "-")</MudTd>
                            <MudTd DataLabel="LINKED RESIDENT" Class="settings-cell-muted">@GetLinkedResidentName(user.Resident)</MudTd>
                            <MudTd DataLabel="ACTIVE">
                                <MudChip T="string" Size="Size.Small"
                                         Style="@GetActiveChipStyle(user.IsActive)">
                                    @(user.IsActive ? "Active" : "Inactive")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="LAST LOGIN" Class="settings-cell-muted">@FormatDateTime(user.LastLoginAt, "Never")</MudTd>
                            <MudTd DataLabel="ACTIONS">
                                <div class="settings-inline-actions">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               Style="border-radius:4px; margin-right:4px"
                                               Disabled="@(!user.IsActive)"
                                               OnClick="@(() => DeactivateUserAsync(user))">
                                        Deactivate
                                    </MudButton>

                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Default"
                                               Size="Size.Small"
                                               Style="border-radius:4px"
                                               OnClick="@(() => OpenResetPasswordDialog(user))">
                                        Reset Password
                                    </MudButton>
                                </div>
                            </MudTd>
                        </RowTemplate>

                        <NoRecordsContent>
                            <div class="settings-empty-state">
                                <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Large" Class="settings-empty-icon" />
                                <div class="settings-empty-title">No users found</div>
                                <div class="settings-empty-message">No user accounts are available yet.</div>
                            </div>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
                        </PagerContent>
                    </MudTable>
                </MudTabPanel>

                <MudTabPanel Text="PUROKS">
                    <div class="settings-section-header">
                        <div class="settings-section-title">Purok Management</div>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Style="border-radius:4px"
                                   OnClick="OpenAddPurokDialog">
                            Add Purok
                        </MudButton>
                    </div>

                    <MudTable T="Purok"
                              Items="_puroks"
                              Elevation="0"
                              Striped="false"
                              Hover="true"
                              RowStyle="height:52px"
                              RowsPerPage="10"
                              Loading="_isLoadingPuroks"
                              Style="border:1px solid #E2E8F0; border-radius:4px; background:#FFFFFF;">
                        <HeaderContent>
                            <MudTh>NAME</MudTh>
                            <MudTh>DESCRIPTION</MudTh>
                            <MudTh>RESIDENTS</MudTh>
                            <MudTh>HOUSEHOLDS</MudTh>
                            <MudTh>ACTIONS</MudTh>
                        </HeaderContent>

                        <RowTemplate Context="purok">
                            <MudTd DataLabel="NAME" Class="settings-cell-strong">@purok.Name</MudTd>
                            <MudTd DataLabel="DESCRIPTION" Class="settings-cell-muted">@(string.IsNullOrWhiteSpace(purok.Description) ? "-" : purok.Description)</MudTd>
                            <MudTd DataLabel="RESIDENTS" Class="settings-cell-dark">@purok.Residents.Count</MudTd>
                            <MudTd DataLabel="HOUSEHOLDS" Class="settings-cell-dark">@purok.Households.Count</MudTd>
                            <MudTd DataLabel="ACTIONS">
                                <div class="settings-inline-actions">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Default"
                                               Size="Size.Small"
                                               Style="border-radius:4px"
                                               OnClick="@(() => OpenEditPurokDialog(purok))">
                                        Edit
                                    </MudButton>

                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               Style="border-radius:4px"
                                               OnClick="@(() => PromptDeletePurokAsync(purok))">
                                        Delete
                                    </MudButton>
                                </div>
                            </MudTd>
                        </RowTemplate>

                        <NoRecordsContent>
                            <div class="settings-empty-state">
                                <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" Class="settings-empty-icon" />
                                <div class="settings-empty-title">No puroks found</div>
                                <div class="settings-empty-message">Add puroks to organize residents and households.</div>
                            </div>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
                        </PagerContent>
                    </MudTable>
                </MudTabPanel>

                <MudTabPanel Text="AUDIT LOG">
                    <MudGrid Spacing="2" Style="margin-bottom:16px;">
                        <MudItem xs="12" md="3">
                            <MudTextField T="string"
                                          Value="_auditUsernameFilter"
                                          ValueChanged="HandleAuditUsernameChanged"
                                          Placeholder="Filter by username..."
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.None"
                                          Style="border-radius:4px;"
                                          Immediate="true"
                                          OnKeyUp="HandleAuditFilterKeyUp" />
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudSelect T="string" @onblur="StateHasChanged"
                                       Value="_auditActionFilter"
                                       ValueChanged="HandleAuditActionChanged"
                                       Placeholder="Filter by action"
                                       Variant="Variant.Outlined"
                                       Style="border-radius:4px;"
                                       Clearable="true">
                                <MudSelectItem Value="@string.Empty">All Actions</MudSelectItem>
                                <MudSelectItem Value="@("Login")">Login</MudSelectItem>
                                <MudSelectItem Value="@("Create")">Create</MudSelectItem>
                                <MudSelectItem Value="@("Update")">Update</MudSelectItem>
                                <MudSelectItem Value="@("Delete")">Delete</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudSelect T="string" @onblur="StateHasChanged"
                                       Value="_auditTableFilter"
                                       ValueChanged="HandleAuditTableChanged"
                                       Placeholder="Filter by table"
                                       Variant="Variant.Outlined"
                                       Style="border-radius:4px;"
                                       Clearable="true">
                                <MudSelectItem Value="@string.Empty">All Tables</MudSelectItem>
                                <MudSelectItem Value="@("Users")">Users</MudSelectItem>
                                <MudSelectItem Value="@("Residents")">Residents</MudSelectItem>
                                <MudSelectItem Value="@("Households")">Households</MudSelectItem>
                                <MudSelectItem Value="@("Events")">Events</MudSelectItem>
                                <MudSelectItem Value="@("Attendances")">Attendances</MudSelectItem>
                                <MudSelectItem Value="@("InteractionLogs")">InteractionLogs</MudSelectItem>
                                <MudSelectItem Value="@("BlotterEntries")">BlotterEntries</MudSelectItem>
                                <MudSelectItem Value="@("ClearanceRequests")">ClearanceRequests</MudSelectItem>
                                <MudSelectItem Value="@("Puroks")">Puroks</MudSelectItem>
                                <MudSelectItem Value="@("BarangaySettings")">BarangaySettings</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="3">
                            <MudDateRangePicker DateRange="_auditDateRange"
                                                DateRangeChanged="HandleAuditDateRangeChanged"
                                                Placeholder="Filter by date range"
                                                Variant="Variant.Outlined"
                                                Style="border-radius:4px;"
                                                DateFormat="MMM dd, yyyy" />
                        </MudItem>
                    </MudGrid>

                    <MudTable T="AuditLogModel"
                              Items="_filteredAuditLogs"
                              Elevation="0"
                              Striped="false"
                              Hover="true"
                              RowStyle="height:52px"
                              RowsPerPage="10"
                              Loading="_isLoadingAuditLogs"
                              Style="border:1px solid #E2E8F0; border-radius:4px; background:#FFFFFF;">
                        <HeaderContent>
                            <MudTh>TIMESTAMP</MudTh>
                            <MudTh>USERNAME</MudTh>
                            <MudTh>ACTION</MudTh>
                            <MudTh>TABLE</MudTh>
                            <MudTh>RECORD ID</MudTh>
                            <MudTh>DETAILS</MudTh>
                        </HeaderContent>

                        <RowTemplate Context="log">
                            <MudTd DataLabel="TIMESTAMP" Class="settings-cell-muted">@FormatDateTime(log.Timestamp, "-")</MudTd>
                            <MudTd DataLabel="USERNAME" Class="settings-cell-dark">@(log.User?.Username ?? "-")</MudTd>
                            <MudTd DataLabel="ACTION" Class="settings-cell-strong">@log.Action</MudTd>
                            <MudTd DataLabel="TABLE" Class="settings-cell-muted">@log.TableAffected</MudTd>
                            <MudTd DataLabel="RECORD ID" Class="settings-cell-muted">@(log.RecordId?.ToString() ?? "-")</MudTd>
                            <MudTd DataLabel="DETAILS" Class="settings-cell-muted">
                                <div class="settings-truncate" title="@log.Details">@(string.IsNullOrWhiteSpace(log.Details) ? "-" : log.Details)</div>
                            </MudTd>
                        </RowTemplate>

                        <NoRecordsContent>
                            <div class="settings-empty-state">
                                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Class="settings-empty-icon" />
                                <div class="settings-empty-title">No audit logs found</div>
                                <div class="settings-empty-message">No audit logs matched the current filters.</div>
                            </div>
                        </NoRecordsContent>

                        <PagerContent>
                            <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" />
                        </PagerContent>
                    </MudTable>
                </MudTabPanel>
            </MudTabs>
        }
    </div>
}

<MudDialog @bind-Visible="_addUserDialogOpen"
           Options="_smallDialogOptions"
           TitleClass="settings-dialog-title"
           ContentClass="settings-dialog-content"
           ActionsClass="settings-dialog-actions">
    <TitleContent>
        <MudText Typo="Typo.h6">Add User</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="_addUserModel">
            <DataAnnotationsValidator />

            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="_addUserModel.Username"
                                  For="@(() => _addUserModel.Username)"
                                  Label="Username"
                                  Variant="Variant.Outlined"
                                  Style="border-radius:4px"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="_addUserModel.Password"
                                  For="@(() => _addUserModel.Password)"
                                  Label="Password"
                                  Variant="Variant.Outlined"
                                  Style="border-radius:4px"
                                  FullWidth="true"
                                  InputType="@(_showAddUserPassword ? InputType.Text : InputType.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showAddUserPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                  OnAdornmentClick="ToggleAddUserPasswordVisibility" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="int" @onblur="StateHasChanged"
                               @bind-Value="_addUserModel.RoleId"
                               For="@(() => _addUserModel.RoleId)"
                               Label="Role"
                               Variant="Variant.Outlined"
                               Style="border-radius:4px"
                               FullWidth="true">
                        @foreach (var role in OrderedRoles)
                        {
                            <MudSelectItem Value="@role.RoleId">@role.RoleName</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudAutocomplete T="Resident"
                                     Label="Linked Resident"
                                     Variant="Variant.Outlined"
                                     Style="border-radius:4px"
                                     FullWidth="true"
                                     SearchFunc="SearchLinkedResidentsAsync"
                                     ToStringFunc="FormatResidentFullName"
                                     Value="_selectedLinkedResident"
                                     ValueChanged="HandleLinkedResidentChanged"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="true"
                                     Clearable="true" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   Style="border-radius:4px"
                   OnClick="CloseAddUserDialog">
            Cancel
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Style="border-radius:4px"
                   OnClick="SaveNewUserAsync">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_resetPasswordDialogOpen"
           Options="_extraSmallDialogOptions"
           TitleClass="settings-dialog-title"
           ContentClass="settings-dialog-content"
           ActionsClass="settings-dialog-actions">
    <TitleContent>
        <MudText Typo="Typo.h6">Reset Password</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string"
                      @bind-Value="_newPassword"
                      Label="New Password"
                      Variant="Variant.Outlined"
                      Style="border-radius:4px"
                      FullWidth="true"
                      InputType="@(_showResetPassword ? InputType.Text : InputType.Password)"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_showResetPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="ToggleResetPasswordVisibility" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   Style="border-radius:4px"
                   OnClick="CloseResetPasswordDialog">
            Cancel
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Style="border-radius:4px"
                   OnClick="SaveResetPasswordAsync">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_purokDialogOpen"
           Options="_smallDialogOptions"
           TitleClass="settings-dialog-title"
           ContentClass="settings-dialog-content"
           ActionsClass="settings-dialog-actions">
    <TitleContent>
        <MudText Typo="Typo.h6">@PurokDialogTitle</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="_purokModel">
            <DataAnnotationsValidator />

            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="_purokModel.Name"
                                  For="@(() => _purokModel.Name)"
                                  Label="Purok Name"
                                  Variant="Variant.Outlined"
                                  Style="border-radius:4px"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="_purokModel.Description"
                                  Label="Description"
                                  Variant="Variant.Outlined"
                                  Style="border-radius:4px"
                                  FullWidth="true"
                                  Lines="4" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   Style="border-radius:4px"
                   OnClick="ClosePurokDialog">
            Cancel
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Style="border-radius:4px"
                   Disabled="_isSavingPurok"
                   OnClick="SavePurokAsync">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private readonly DialogOptions _smallDialogOptions = new()
    {
        FullWidth = true,
        MaxWidth = MaxWidth.Small,
        CloseOnEscapeKey = true
    };

    private readonly DialogOptions _extraSmallDialogOptions = new()
    {
        FullWidth = true,
        MaxWidth = MaxWidth.ExtraSmall,
        CloseOnEscapeKey = true
    };

    private readonly AddUserModel _addUserModel = new();
    private readonly PurokFormModel _purokModel = new();
    private BarangaySettings _settingsModel = new() { SettingId = 1 };
    private List<User> _users = [];
    private List<Purok> _puroks = [];
    private List<Role> _roles = [];
    private List<AuditLogModel> _auditLogs = [];
    private List<AuditLogModel> _filteredAuditLogs = [];
    private bool _isAuthorized = true;
    private bool _isLoading = true;
    private bool _isLoadingUsers;
    private bool _isLoadingPuroks;
    private bool _isLoadingAuditLogs;
    private bool _isSavingSettings;
    private bool _isSavingPurok;
    private bool _addUserDialogOpen;
    private bool _resetPasswordDialogOpen;
    private bool _purokDialogOpen;
    private bool _showAddUserPassword;
    private bool _showResetPassword;
    private Resident? _selectedLinkedResident;
    private User? _selectedResetUser;
    private string _newPassword = string.Empty;
    private string _auditUsernameFilter = string.Empty;
    private string _auditActionFilter = string.Empty;
    private string _auditTableFilter = string.Empty;
    private DateRange _auditDateRange = new(null, null);
    private int? _editingPurokId;

    private int CurrentUserId => AuthService.CurrentUser?.UserId ?? 1;
    private string PurokDialogTitle => _editingPurokId.HasValue ? "Edit Purok" : "Add Purok";

    private IEnumerable<Role> OrderedRoles =>
        _roles.OrderBy(role => GetRoleOrder(role.RoleName));

    protected override async Task OnInitializedAsync()
    {
        if (!string.Equals(AuthService.GetCurrentRole(), "Captain", StringComparison.OrdinalIgnoreCase))
        {
            _isAuthorized = false;
            NavigationManager.NavigateTo("/dashboard", false);
            return;
        }

        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        _isLoading = true;

        var settings = await DbContext.BarangaySettings
            .AsNoTracking()
            .FirstOrDefaultAsync(candidate => candidate.SettingId == 1);

        _settingsModel = settings ?? new BarangaySettings { SettingId = 1 };

        _roles = await AuthService.GetAllRolesAsync();
        if (_roles.Count > 0 && _addUserModel.RoleId <= 0)
        {
            _addUserModel.RoleId = OrderedRoles.First().RoleId;
        }

        await LoadUsersAsync();
        await LoadPuroksAsync();
        await LoadAuditLogsAsync();

        _isLoading = false;
    }

    private async Task LoadUsersAsync()
    {
        _isLoadingUsers = true;
        _users = await AuthService.GetAllUsersAsync();
        _isLoadingUsers = false;
    }

    private async Task LoadPuroksAsync()
    {
        _isLoadingPuroks = true;
        _puroks = await DbContext.Puroks
            .Include(purok => purok.Residents.Where(resident => !resident.IsDeleted))
            .Include(purok => purok.Households)
            .AsNoTracking()
            .OrderBy(purok => purok.Name)
            .ToListAsync();
        _isLoadingPuroks = false;
    }

    private async Task LoadAuditLogsAsync()
    {
        _isLoadingAuditLogs = true;
        _auditLogs = await AuditService.GetAllLogsAsync();
        ApplyAuditFilters();
        _isLoadingAuditLogs = false;
    }

    private void HandleAuditUsernameChanged(string value)
    {
        _auditUsernameFilter = value;
        ApplyAuditFilters();
    }

    private void HandleAuditActionChanged(string value)
    {
        _auditActionFilter = value;
        ApplyAuditFilters();
    }

    private void HandleAuditTableChanged(string value)
    {
        _auditTableFilter = value;
        ApplyAuditFilters();
    }

    private void HandleAuditDateRangeChanged(DateRange range)
    {
        _auditDateRange = range;
        ApplyAuditFilters();
    }

    private void HandleAuditFilterKeyUp(KeyboardEventArgs _)
    {
        ApplyAuditFilters();
    }

    private void ApplyAuditFilters()
    {
        _filteredAuditLogs = _auditLogs
            .Where(log =>
            {
                var logDate = ParseAuditTimestamp(log.Timestamp);

                return (string.IsNullOrEmpty(_auditUsernameFilter) ||
                        (log.User?.Username?.Contains(_auditUsernameFilter, StringComparison.OrdinalIgnoreCase) ?? false)) &&
                       (string.IsNullOrEmpty(_auditActionFilter) ||
                        log.Action == _auditActionFilter) &&
                       (string.IsNullOrEmpty(_auditTableFilter) ||
                        log.TableAffected == _auditTableFilter) &&
                       (!_auditDateRange.Start.HasValue ||
                        (logDate.HasValue && logDate.Value.Date >= _auditDateRange.Start.Value.Date)) &&
                       (!_auditDateRange.End.HasValue ||
                        (logDate.HasValue && logDate.Value.Date <= _auditDateRange.End.Value.Date));
            })
            .ToList();

        StateHasChanged();
    }

    private async Task SaveSettingsAsync()
    {
        if (_isSavingSettings)
        {
            return;
        }

        _isSavingSettings = true;

        try
        {
            var existingSettings = await DbContext.BarangaySettings
                .FirstOrDefaultAsync(candidate => candidate.SettingId == 1);

            if (existingSettings is null)
            {
                _settingsModel.SettingId = 1;
                _settingsModel.BarangayName = _settingsModel.BarangayName.Trim();
                _settingsModel.Municipality = _settingsModel.Municipality.Trim();
                _settingsModel.Province = _settingsModel.Province.Trim();
                _settingsModel.CaptainName = NullIfWhiteSpace(_settingsModel.CaptainName);
                _settingsModel.SecretaryName = NullIfWhiteSpace(_settingsModel.SecretaryName);
                _settingsModel.ContactNumber = NullIfWhiteSpace(_settingsModel.ContactNumber);
                _settingsModel.LogoPath = NullIfWhiteSpace(_settingsModel.LogoPath);
                _settingsModel.UpdatedAt = DateTime.UtcNow.ToString("O");
                _settingsModel.UpdatedBy = CurrentUserId;
                DbContext.BarangaySettings.Add(_settingsModel);
            }
            else
            {
                existingSettings.BarangayName = _settingsModel.BarangayName.Trim();
                existingSettings.Municipality = _settingsModel.Municipality.Trim();
                existingSettings.Province = _settingsModel.Province.Trim();
                existingSettings.CaptainName = NullIfWhiteSpace(_settingsModel.CaptainName);
                existingSettings.SecretaryName = NullIfWhiteSpace(_settingsModel.SecretaryName);
                existingSettings.ContactNumber = NullIfWhiteSpace(_settingsModel.ContactNumber);
                existingSettings.LogoPath = NullIfWhiteSpace(_settingsModel.LogoPath);
                existingSettings.UpdatedAt = DateTime.UtcNow.ToString("O");
                existingSettings.UpdatedBy = CurrentUserId;
            }

            await DbContext.SaveChangesAsync();

            await AuditService.LogAsync(
                CurrentUserId,
                "Update Settings",
                "BarangaySettings",
                1,
                "Updated barangay information.");

            Snackbar.Add("Settings saved.", Severity.Success);
        }
        finally
        {
            _isSavingSettings = false;
        }
    }

