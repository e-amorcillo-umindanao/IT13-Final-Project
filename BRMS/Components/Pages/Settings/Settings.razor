    private static string GetLinkedResidentName(Resident? resident)
    {
        return resident is null ? "-" : FormatResidentFullName(resident);
    }

    private static string FormatResidentFullName(Resident? resident)
    {
        if (resident is null)
        {
            return string.Empty;
        }

        return string.Join(" ", new[] { resident.FirstName, resident.MiddleName, resident.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static string FormatDateTime(string? value, string fallback)
    {
        return DateTime.TryParse(value, out var parsedDate)
            ? parsedDate.ToString("MMM dd, yyyy hh:mm tt")
            : fallback;
    }

    private static DateTime? ParseAuditTimestamp(string? value)
    {
        return DateTime.TryParse(value, out var parsedDate) ? parsedDate : null;
    }

    private static string GetActiveChipStyle(bool isActive)
    {
        return isActive
            ? "background:#22C55E;color:#FFFFFF;border-radius:4px;box-shadow:none;"
            : "background:#94A3B8;color:#FFFFFF;border-radius:4px;box-shadow:none;";
    }

    private static int GetRoleOrder(string? roleName)
    {
        return roleName?.Trim() switch
        {
            "Captain" => 0,
            "Kagawad" => 1,
            "Staff" => 2,
            "Resident" => 3,
            _ => 99
        };
    }

    private static string? NullIfWhiteSpace(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

