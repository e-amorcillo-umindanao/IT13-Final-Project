    private async Task SavePurokAsync()
    {
        if (_isSavingPurok || string.IsNullOrWhiteSpace(_purokModel.Name))
        {
            Snackbar.Add("Purok name is required.", Severity.Error);
            return;
        }

        _isSavingPurok = true;

        try
        {
            var normalizedName = _purokModel.Name.Trim();
            var normalizedDescription = NullIfWhiteSpace(_purokModel.Description);

            var duplicateExists = await DbContext.Puroks.AnyAsync(purok =>
                purok.Name == normalizedName &&
                (!_editingPurokId.HasValue || purok.PurokId != _editingPurokId.Value));

            if (duplicateExists)
            {
                Snackbar.Add("A purok with the same name already exists.", Severity.Error);
                return;
            }

            if (_editingPurokId.HasValue)
            {
                var existingPurok = await DbContext.Puroks
                    .FirstOrDefaultAsync(purok => purok.PurokId == _editingPurokId.Value);

                if (existingPurok is null)
                {
                    Snackbar.Add("Purok could not be found.", Severity.Error);
                    return;
                }

                existingPurok.Name = normalizedName;
                existingPurok.Description = normalizedDescription;
                await DbContext.SaveChangesAsync();

                await AuditService.LogAsync(
                    CurrentUserId,
                    "Update",
                    "Puroks",
                    existingPurok.PurokId,
                    $"Updated purok {existingPurok.Name}.");

                Snackbar.Add("Purok updated.", Severity.Success);
            }
            else
            {
                var purok = new Purok
                {
                    Name = normalizedName,
                    Description = normalizedDescription,
                    CreatedAt = DateTime.UtcNow.ToString("O")
                };

                DbContext.Puroks.Add(purok);
                await DbContext.SaveChangesAsync();

                await AuditService.LogAsync(
                    CurrentUserId,
                    "Create",
                    "Puroks",
                    purok.PurokId,
                    $"Created purok {purok.Name}.");

                Snackbar.Add("Purok created.", Severity.Success);
            }

            ClosePurokDialog();
            await LoadPuroksAsync();
            await LoadAuditLogsAsync();
        }
        finally
        {
            _isSavingPurok = false;
        }
    }

    private async Task PromptDeletePurokAsync(Purok purok)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Title)] = "Delete Purok",
            [nameof(ConfirmDialog.Message)] = $"Delete purok {purok.Name}?",
            [nameof(ConfirmDialog.ConfirmText)] = "Delete",
            [nameof(ConfirmDialog.OnConfirm)] = EventCallback.Factory.Create(this, () => DeletePurokAsync(purok.PurokId))
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraSmall
        };

        await DialogService.ShowAsync<ConfirmDialog>(string.Empty, parameters, options);
    }

    private async Task DeletePurokAsync(int purokId)
    {
        var purok = await DbContext.Puroks
            .Include(candidate => candidate.Residents.Where(resident => !resident.IsDeleted))
            .Include(candidate => candidate.Households)
            .FirstOrDefaultAsync(candidate => candidate.PurokId == purokId);

        if (purok is null)
        {
            Snackbar.Add("Purok could not be found.", Severity.Error);
            return;
        }

        if (purok.Residents.Count > 0 || purok.Households.Count > 0)
        {
            Snackbar.Add("Cannot delete purok while residents or households are still assigned.", Severity.Error);
            return;
        }

        DbContext.Puroks.Remove(purok);
        await DbContext.SaveChangesAsync();

        await AuditService.LogAsync(
            CurrentUserId,
            "Delete",
            "Puroks",
            purok.PurokId,
            $"Deleted purok {purok.Name}.");

        Snackbar.Add("Purok deleted.", Severity.Success);
        await LoadPuroksAsync();
        await LoadAuditLogsAsync();
    }

