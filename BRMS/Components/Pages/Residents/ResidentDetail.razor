@page "/residents/{Id:int}"
@inject ResidentService ResidentService
@inject AppDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Resident Details</PageTitle>

<div class="page-shell">
    @if (_isLoading)
    {
        <MudPaper Class="page-card" Elevation="0">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </MudPaper>
    }
    else if (_resident is null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">Resident not found.</MudAlert>
    }
    else
    {
        <div class="page-header">
            <h1 class="page-title">@ResidentName</h1>

            <div class="page-header-actions">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Style="border-radius: 4px"
                           OnClick="@(() => NavigationManager.NavigateTo($"/residents/edit/{_resident.ResidentId}"))">
                    Edit
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Style="border-radius: 4px"
                           OnClick="@(() => NavigationManager.NavigateTo($"/engagement/log/{_resident.ResidentId}"))">
                    Log Interaction
                </MudButton>
            </div>
        </div>

        <MudPaper Elevation="0"
                  Style="border: 1px solid #E2E8F0; border-radius: 4px; background: #FFFFFF; padding: 24px;">
            <div class="detail-grid">
                <div class="detail-field">
                    <div class="detail-label">First Name</div>
                    <div class="detail-value">@_resident.FirstName</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Last Name</div>
                    <div class="detail-value">@_resident.LastName</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Middle Name</div>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(_resident.MiddleName) ? "-" : _resident.MiddleName)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Birth Date</div>
                    <div class="detail-value">@FormatDate(_resident.BirthDate)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Age</div>
                    <div class="detail-value">@GetAge(_resident.BirthDate)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Gender</div>
                    <div class="detail-value">@_resident.Gender</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Civil Status</div>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(_resident.CivilStatus) ? "-" : _resident.CivilStatus)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Contact Number</div>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(_resident.ContactNumber) ? "-" : _resident.ContactNumber)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Email</div>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(_resident.Email) ? "-" : _resident.Email)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Address</div>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(_resident.Address) ? "-" : _resident.Address)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Purok</div>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(_resident.Purok?.Name) ? "-" : _resident.Purok!.Name)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Household</div>
                    <div class="detail-value">@(string.IsNullOrWhiteSpace(_resident.Household?.HouseholdNumber) ? "-" : _resident.Household!.HouseholdNumber)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Status</div>
                    <div class="detail-value">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Style="@GetStatusChipStyle(_resident.Status)">
                            @_resident.Status
                        </MudChip>
                    </div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Categories</div>
                    <div class="detail-value">
                        @if (ResidentCategories.Count == 0)
                        {
                            <span>-</span>
                        }
                        else
                        {
                            <div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;">
                                @foreach (var category in ResidentCategories)
                                {
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Style="background-color: #E2E8F0; color: #1E293B; border-radius: 4px !important; font-size: 0.75rem;">
                                        @category
                                    </MudChip>
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Residency Since</div>
                    <div class="detail-value">@FormatDate(_resident.ResidencySince)</div>
                </div>
                <div class="detail-field">
                    <div class="detail-label">Engagement</div>
                    <div class="detail-value">
                        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Style="@GetEngagementChipStyle(_engagementScore)">
                                @GetEngagementLabel(_engagementScore)
                            </MudChip>
                            <MudText Style="color: #64748B; font-size: 0.875rem;">@_engagementScore / 100</MudText>
                        </div>
                    </div>
                </div>
            </div>
        </MudPaper>

        <MudPaper Class="page-card" Elevation="0">
            <MudTabs Rounded="false">
                <MudTabPanel Text="Interaction History">
                    @if (_orderedInteractions.Count == 0)
                    {
                        <MudText Typo="Typo.body2">No interaction history found.</MudText>
                    }
                    else
                    {
                        <div class="history-list">
                            @foreach (var interaction in _orderedInteractions)
                            {
                                <div class="history-item">
                                    <div class="history-item-title">@interaction.InteractionType</div>
                                    <div class="history-item-meta">@FormatDate(interaction.InteractionDate)</div>
                                    <MudText Typo="Typo.body2">@interaction.Notes</MudText>
                                </div>
                            }
                        </div>
                    }
                </MudTabPanel>

                <MudTabPanel Text="Event Attendance History">
                    @if (_orderedAttendances.Count == 0)
                    {
                        <MudText Typo="Typo.body2">No event attendance history found.</MudText>
                    }
                    else
                    {
                        <div class="history-list">
                            @foreach (var attendance in _orderedAttendances)
                            {
                                <div class="history-item">
                                    <div class="history-item-title">@(attendance.Event?.Title ?? "Barangay Event")</div>
                                    <div class="history-item-meta">@FormatDate(attendance.Event?.EventDate) | @attendance.Status</div>
                                    <MudText Typo="Typo.body2">Recorded at @FormatDate(attendance.RecordedAt)</MudText>
                                </div>
                            }
                        </div>
                    }
                </MudTabPanel>

                <MudTabPanel Text="Clearance History">
                    @if (_orderedClearances.Count == 0)
                    {
                        <MudText Typo="Typo.body2">No clearance history found.</MudText>
                    }
                    else
                    {
                        <div class="history-list">
                            @foreach (var clearance in _orderedClearances)
                            {
                                <div class="history-item">
                                    <div class="history-item-title">@clearance.Purpose</div>
                                    <div class="history-item-meta">@FormatDate(clearance.RequestedAt) | @clearance.Status</div>
                                    <MudText Typo="Typo.body2">Remarks: @(string.IsNullOrWhiteSpace(clearance.Remarks) ? "-" : clearance.Remarks)</MudText>
                                </div>
                            }
                        </div>
                    }
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Resident? _resident;
    private bool _isLoading = true;
    private int _engagementScore;
    private List<InteractionLog> _orderedInteractions = [];
    private List<Attendance> _orderedAttendances = [];
    private List<ClearanceRequest> _orderedClearances = [];

    private string ResidentName => _resident is null
        ? "Resident Details"
        : string.Join(" ", new[] { _resident.FirstName, _resident.MiddleName, _resident.LastName }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private IReadOnlyList<string> ResidentCategories =>
        string.IsNullOrWhiteSpace(_resident?.Categories)
            ? []
            : _resident.Categories
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(category => !string.IsNullOrWhiteSpace(category))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        _resident = await ResidentService.GetResidentByIdAsync(Id);

        if (_resident is not null)
        {
            _orderedInteractions = _resident.InteractionLogs
                .OrderByDescending(log => ParseDate(log.InteractionDate) ?? DateTime.MinValue)
                .ToList();

            _orderedAttendances = _resident.Attendances
                .OrderByDescending(attendance => ParseDate(attendance.Event?.EventDate) ?? DateTime.MinValue)
                .ToList();

            _orderedClearances = _resident.ClearanceRequests
                .OrderByDescending(clearance => ParseDate(clearance.RequestedAt) ?? DateTime.MinValue)
                .ToList();

            await CalculateEngagementAsync();
        }

        _isLoading = false;
    }

    private async Task CalculateEngagementAsync()
    {
        if (_resident is null)
        {
            return;
        }

        var totalEvents = await DbContext.Events.AsNoTracking().CountAsync();
        var eventsAttended = _resident.Attendances.Count(attendance => IsAttendedStatus(attendance.Status));
        var cutoffDate = DateTime.Today.AddMonths(-6);
        var interactionsLast6Months = _resident.InteractionLogs.Count(log =>
        {
            var interactionDate = ParseDate(log.InteractionDate);
            return interactionDate.HasValue && interactionDate.Value.Date >= cutoffDate;
        });

        var lastInteractionDate = _resident.InteractionLogs
            .Select(log => ParseDate(log.InteractionDate))
            .Where(date => date.HasValue)
            .Max();

        _engagementScore = EngagementCalculator.CalculateScore(totalEvents, eventsAttended, interactionsLast6Months, lastInteractionDate);
    }

    private static bool IsAttendedStatus(string status)
    {
        return status.Equals("Attended", StringComparison.OrdinalIgnoreCase) ||
               status.Equals("Present", StringComparison.OrdinalIgnoreCase);
    }

    private static DateTime? ParseDate(string? value)
    {
        return DateTime.TryParse(value, out var parsedDate) ? parsedDate : null;
    }

    private static string FormatDate(string? value)
    {
        return ParseDate(value)?.ToString("MMMM dd, yyyy") ?? "-";
    }

    private static int GetAge(string? birthDate)
    {
        var parsedBirthDate = ParseDate(birthDate);
        if (!parsedBirthDate.HasValue)
        {
            return 0;
        }

        var age = DateTime.Today.Year - parsedBirthDate.Value.Year;
        if (parsedBirthDate.Value.Date > DateTime.Today.AddYears(-age))
        {
            age--;
        }

        return Math.Max(age, 0);
    }

    private static string GetStatusChipStyle(string? status)
    {
        return status?.Trim() switch
        {
            "Active" => "background-color: #22C55E; color: white; border-radius: 4px !important; font-size: 0.75rem;",
            "Inactive" => "background-color: #94A3B8; color: white; border-radius: 4px !important; font-size: 0.75rem;",
            "Transferred" => "background-color: #3B5BDB; color: white; border-radius: 4px !important; font-size: 0.75rem;",
            "Deceased" => "background-color: #EF4444; color: white; border-radius: 4px !important; font-size: 0.75rem;",
            _ => "background-color: #94A3B8; color: white; border-radius: 4px !important; font-size: 0.75rem;"
        };
    }

    private static string GetEngagementLabel(int score)
    {
        return score switch
        {
            >= 75 => "High",
            >= 40 => "Medium",
            _ => "Low"
        };
    }

    private static string GetEngagementChipStyle(int score)
    {
        return score switch
        {
            >= 75 => "background-color: #22C55E; color: white; border-radius: 4px !important; font-size: 0.75rem;",
            >= 40 => "background-color: #F59E0B; color: white; border-radius: 4px !important; font-size: 0.75rem;",
            _ => "background-color: #EF4444; color: white; border-radius: 4px !important; font-size: 0.75rem;"
        };
    }
}
