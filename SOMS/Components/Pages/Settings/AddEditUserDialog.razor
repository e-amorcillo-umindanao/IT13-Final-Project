@using System.ComponentModel.DataAnnotations
@inject SettingsService SettingsService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudForm @ref="_form" Model="_model">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Username*"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      For="@(() => _model.Username)"
                                      @bind-Value="_model.Username"
                                      Disabled="@IsEditMode"
                                      Required="true"
                                      RequiredError="Username is required." />
                    </MudItem>

                    @if (!IsEditMode)
                    {
                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Password*"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          InputType="InputType.Password"
                                          For="@(() => _model.Password)"
                                          @bind-Value="_model.Password"
                                          Required="true"
                                          RequiredError="Password is required." />
                        </MudItem>
                    }

                    @if (!ResetPasswordOnly)
                    {
                        <MudItem xs="12" md="6">
                            <MudSelect T="int"
                                       Label="Role*"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       For="@(() => _model.RoleId)"
                                       @bind-Value="_model.RoleId">
                                @foreach (var role in _roles)
                                {
                                    <MudSelectItem T="int" Value="@role.RoleId">@role.RoleName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="MemberLookupItem"
                                             Label="Link to Member"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             Value="_selectedMember"
                                             ValueChanged="OnSelectedMemberChangedAsync"
                                             SearchFunc="SearchMembersAsync"
                                             ToStringFunc="@(member => member is null ? string.Empty : $"{member.FullName} ({member.StudentId})")"
                                             ResetValueOnEmptyText="true"
                                             Clearable="true"
                                             CoerceText="false" />
                        </MudItem>

                        @if (IsEditMode)
                        {
                            <MudItem xs="12">
                                <MudSwitch T="bool"
                                           Color="Color.Primary"
                                           Label="@(_model.IsActive ? "Active" : "Inactive")"
                                           @bind-Value="_model.IsActive" />
                            </MudItem>
                        }
                    }

                    @if (IsEditMode)
                    {
                        <MudItem xs="12">
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.subtitle2">Reset Password</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                Leave blank to keep the current password.
                            </MudText>
                            <MudTextField T="string"
                                          Label="New Password"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          InputType="InputType.Password"
                                          @bind-Value="_model.NewPassword" />
                        </MudItem>
                    }
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel" Disabled="_isSaving">
            Cancel
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_isSaving || _isLoading">
            @if (_isSaving)
            {
                <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                <span>Saving...</span>
            }
            else
            {
                <span>Save</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public int? UserId { get; set; }

    [Parameter]
    public bool ResetPasswordOnly { get; set; }

    private MudForm? _form;
    private UserEditorModel _model = new();
    private List<Role> _roles = [];
    private MemberLookupItem? _selectedMember;
    private bool _isLoading = true;
    private bool _isSaving;

    private bool IsEditMode => UserId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        _roles = await SettingsService.GetRolesAsync();

        if (IsEditMode)
        {
            var user = await SettingsService.GetUserByIdAsync(UserId!.Value);
            if (user is null)
            {
                Snackbar.Add("User not found.", Severity.Error);
                MudDialog.Cancel();
                return;
            }

            _model = new UserEditorModel
            {
                Username = user.Username,
                RoleId = user.RoleId,
                IsActive = user.IsActive,
                MemberId = user.MemberId
            };

            if (user.Member is not null)
            {
                _selectedMember = new MemberLookupItem
                {
                    MemberId = user.Member.MemberId,
                    FullName = user.Member.FullName,
                    StudentId = user.Member.StudentId
                };
            }
        }
        else if (_roles.Count > 0)
        {
            _model.RoleId = _roles[0].RoleId;
        }

        _isLoading = false;
    }

    private async Task<IEnumerable<MemberLookupItem>> SearchMembersAsync(string value, CancellationToken token)
    {
        return await SettingsService.SearchLinkableMembersAsync(value, UserId);
    }

    private Task OnSelectedMemberChangedAsync(MemberLookupItem? value)
    {
        _selectedMember = value;
        _model.MemberId = value?.MemberId;
        return Task.CompletedTask;
    }

    private async Task SaveAsync()
    {
        if (_isSaving || _form is null)
        {
            return;
        }

        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        if (ResetPasswordOnly && string.IsNullOrWhiteSpace(_model.NewPassword))
        {
            Snackbar.Add("Enter a new password to continue.", Severity.Error);
            return;
        }

        _isSaving = true;

        try
        {
            if (IsEditMode)
            {
                await SettingsService.UpdateUserAsync(
                    UserId!.Value,
                    _model.RoleId,
                    _model.IsActive,
                    ResetPasswordOnly ? _model.MemberId : _selectedMember?.MemberId,
                    NormalizeOptional(_model.NewPassword));
            }
            else
            {
                await SettingsService.CreateUserAsync(
                    _model.Username,
                    _model.Password,
                    _model.RoleId,
                    _selectedMember?.MemberId);
            }

            var successMessage = !IsEditMode
                ? "User created."
                : ResetPasswordOnly
                    ? "Password reset."
                    : "User updated.";

            Snackbar.Add(successMessage, Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private static string? NormalizeOptional(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class UserEditorModel
    {
        [Required(ErrorMessage = "Username is required.")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Role is required.")]
        public int RoleId { get; set; }

        public bool IsActive { get; set; } = true;

        public int? MemberId { get; set; }

        public string? NewPassword { get; set; }
    }
}
