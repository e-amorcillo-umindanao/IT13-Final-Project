@inject SettingsService SettingsService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudStack Spacing="3">
    <div class="members-page-header">
        <div>
            <MudText Typo="Typo.h6">User Management</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage logins, roles, and account access.</MudText>
        </div>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenAddUserDialogAsync">
            + Add User
        </MudButton>
    </div>

    <MudPaper Class="members-table-shell" Elevation="0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudTable T="User"
                      Items="_users"
                      Dense="true"
                      Hover="true"
                      Elevation="0"
                      RowsPerPage="20"
                      Breakpoint="Breakpoint.Sm"
                      Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                <HeaderContent>
                    <MudTh>Username</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Last Login</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Username">@context.Username</MudTd>
                    <MudTd DataLabel="Role">@context.Role.RoleName</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Last Login">@FormatLastLogin(context.LastLoginAt)</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" Spacing="1">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => OpenEditUserDialogAsync(context.UserId))">
                                Edit
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.LockReset"
                                       OnClick="@(() => OpenResetPasswordDialogAsync(context.UserId))">
                                Reset Password
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-4">
                        <EmptyState Message="No user accounts have been created yet." Icon="@Icons.Material.Filled.ManageAccounts" />
                    </div>
                </NoRecordsContent>
            </MudTable>
        }
    </MudPaper>
</MudStack>

@code {
    private List<User> _users = [];
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _users = await SettingsService.GetUsersAsync();
        _isLoading = false;
    }

    private async Task OpenAddUserDialogAsync()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditUserDialog>("Add User", options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    private async Task OpenEditUserDialogAsync(int userId)
    {
        var parameters = new DialogParameters
        {
            [nameof(AddEditUserDialog.UserId)] = userId
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditUserDialog>("Edit User", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    private async Task OpenResetPasswordDialogAsync(int userId)
    {
        var parameters = new DialogParameters
        {
            [nameof(AddEditUserDialog.UserId)] = userId,
            [nameof(AddEditUserDialog.ResetPasswordOnly)] = true
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditUserDialog>("Reset Password", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    private static string FormatLastLogin(DateTime? value)
        => value.HasValue ? value.Value.ToString("MMM dd, yyyy hh:mm tt") : "Never";
}
