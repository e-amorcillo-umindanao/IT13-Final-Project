@page "/settings"
@layout MainLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@inject SettingsService SettingsService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Settings</PageTitle>

@if (_isAuthorized is false)
{
    <LoadingSpinner />
}
else
{
    <MudStack Spacing="3">
        <PageHeader Title="Settings" Subtitle="Organization preferences, access control, and audit history" />

        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudPaper Elevation="0" Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                <MudTabs Rounded="false" KeepPanelsAlive="true">
                    <MudTabPanel Text="Organization Settings">
                        <MudCard Elevation="0" Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                            <MudCardContent>
                                <MudForm @ref="_orgForm" Model="_orgSettingsModel">
                                    <MudGrid Spacing="2">
                                        <MudItem xs="12" md="6">
                                            <MudTextField T="string"
                                                          Label="Organization Name*"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          For="@(() => _orgSettingsModel.OrgName)"
                                                          @bind-Value="_orgSettingsModel.OrgName"
                                                          Required="true"
                                                          RequiredError="Organization name is required." />
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudTextField T="string"
                                                          Label="Academic Year*"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          For="@(() => _orgSettingsModel.AcademicYear)"
                                                          @bind-Value="_orgSettingsModel.AcademicYear"
                                                          Required="true"
                                                          RequiredError="Academic year is required." />
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudTextField T="string"
                                                          Label="Semester Label*"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          For="@(() => _orgSettingsModel.SemesterLabel)"
                                                          @bind-Value="_orgSettingsModel.SemesterLabel"
                                                          Required="true"
                                                          RequiredError="Semester label is required." />
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudDatePicker Label="Semester Start"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Date="_orgSettingsModel.SemesterStart"
                                                           DateChanged="OnSemesterStartChanged" />
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudTextField T="string"
                                                          Label="Adviser Name"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          @bind-Value="_orgSettingsModel.AdviserName" />
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudTextField T="string"
                                                          Label="President Name"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          @bind-Value="_orgSettingsModel.PresidentName" />
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudStack Spacing="1">
                                                <MudText Typo="Typo.body2">Logo</MudText>
                                                <MudFileUpload T="IBrowserFile"
                                                               Accept=".png,.jpg,.jpeg,.svg,.webp"
                                                               Hidden="true"
                                                               MaximumFileCount="1"
                                                               FilesChanged="OnLogoChangedAsync">
                                                    <CustomContent>
                                                        <MudButton Variant="Variant.Outlined"
                                                                   Color="Color.Default"
                                                                   StartIcon="@Icons.Material.Filled.Upload"
                                                                   OnClick="context.OpenFilePickerAsync">
                                                            Upload Logo
                                                        </MudButton>
                                                    </CustomContent>
                                                </MudFileUpload>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @GetLogoStatusText()
                                                </MudText>
                                            </MudStack>
                                        </MudItem>
                                    </MudGrid>
                                </MudForm>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="_isSavingOrgSettings"
                                           OnClick="SaveOrgSettingsAsync">
                                    @if (_isSavingOrgSettings)
                                    {
                                        <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Save Settings</span>
                                    }
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudTabPanel>

                    <MudTabPanel Text="User Management">
                        <UserManagement />
                    </MudTabPanel>

                    <MudTabPanel Text="Committees">
                        <MudStack Spacing="3">
                            <div class="members-page-header">
                                <div>
                                    <MudText Typo="Typo.h6">Committees</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Manage committees and review membership assignments.</MudText>
                                </div>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="OpenAddCommitteeDialogAsync">
                                    + Add Committee
                                </MudButton>
                            </div>

                            <MudPaper Class="members-table-shell" Elevation="0">
                                <MudTable T="Committee"
                                          Items="_committees"
                                          Dense="true"
                                          Hover="true"
                                          Elevation="0"
                                          RowsPerPage="20"
                                          Breakpoint="Breakpoint.Sm"
                                          Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                                    <HeaderContent>
                                        <MudTh>Name</MudTh>
                                        <MudTh>Description</MudTh>
                                        <MudTh>Members Count</MudTh>
                                        <MudTh>Created At</MudTh>
                                        <MudTh>Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Name">@context.Name</MudTd>
                                        <MudTd DataLabel="Description">@DisplayValue(context.Description)</MudTd>
                                        <MudTd DataLabel="Members Count">@context.MemberCommittees.Count</MudTd>
                                        <MudTd DataLabel="Created At">@context.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudStack Row="true" Spacing="1">
                                                <MudButton Variant="Variant.Outlined"
                                                           Color="Color.Default"
                                                           Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.Edit"
                                                           OnClick="@(() => OpenEditCommitteeDialogAsync(context.CommitteeId))">
                                                    Edit
                                                </MudButton>
                                                <MudButton Variant="Variant.Outlined"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           StartIcon="@Icons.Material.Filled.DeleteOutline"
                                                           OnClick="@(() => DeleteCommitteeAsync(context))">
                                                    Delete
                                                </MudButton>
                                            </MudStack>
                                        </MudTd>
                                    </RowTemplate>
                                    <NoRecordsContent>
                                        <div class="pa-4">
                                            <EmptyState Message="No committees have been created yet." Icon="@Icons.Material.Filled.Groups2" />
                                        </div>
                                    </NoRecordsContent>
                                </MudTable>
                            </MudPaper>
                        </MudStack>
                    </MudTabPanel>

                    <MudTabPanel Text="Audit Log">
                        <AuditLog />
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        }
    </MudStack>
}

@code {
    private MudForm? _orgForm;
    private OrgSetting _orgSettingsModel = new();
    private List<Committee> _committees = [];
    private IBrowserFile? _selectedLogoFile;
    private string? _existingLogoPath;
    private bool? _isAuthorized;
    private bool _isLoading = true;
    private bool _isSavingOrgSettings;

    protected override async Task OnInitializedAsync()
    {
        if (!string.Equals(AuthService.CurrentRole, "Admin", StringComparison.OrdinalIgnoreCase))
        {
            _isAuthorized = false;
            NavigationManager.NavigateTo("/dashboard", forceLoad: false);
            return;
        }

        _isAuthorized = true;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var orgSettingsTask = SettingsService.GetOrgSettingsAsync();
        var committeesTask = SettingsService.GetCommitteesAsync();

        await Task.WhenAll(orgSettingsTask, committeesTask);

        _orgSettingsModel = await orgSettingsTask;
        _committees = await committeesTask;
        _existingLogoPath = _orgSettingsModel.LogoPath;
        _selectedLogoFile = null;
        _isLoading = false;
    }

    private Task OnSemesterStartChanged(DateTime? value)
    {
        _orgSettingsModel.SemesterStart = value;
        return Task.CompletedTask;
    }

    private Task OnLogoChangedAsync(IBrowserFile? file)
    {
        _selectedLogoFile = file;
        return Task.CompletedTask;
    }

    private async Task SaveOrgSettingsAsync()
    {
        if (_isSavingOrgSettings || _orgForm is null)
        {
            return;
        }

        await _orgForm.ValidateAsync();
        if (!_orgForm.IsValid)
        {
            return;
        }

        _isSavingOrgSettings = true;

        try
        {
            if (_selectedLogoFile is not null)
            {
                _orgSettingsModel.LogoPath = await SaveLogoAsync(_selectedLogoFile, _existingLogoPath);
            }

            await SettingsService.UpdateOrgSettingsAsync(_orgSettingsModel);
            _existingLogoPath = _orgSettingsModel.LogoPath;
            _selectedLogoFile = null;
            Snackbar.Add("Organization settings updated.", Severity.Success);
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        catch (Exception exception)
        {
            Snackbar.Add($"Unable to save settings: {exception.Message}", Severity.Error);
        }
        finally
        {
            _isSavingOrgSettings = false;
        }
    }

    private async Task OpenAddCommitteeDialogAsync()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditCommitteeDialog>("Add Committee", options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadCommitteesAsync();
        }
    }

    private async Task OpenEditCommitteeDialogAsync(int committeeId)
    {
        var parameters = new DialogParameters
        {
            [nameof(AddEditCommitteeDialog.CommitteeId)] = committeeId
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditCommitteeDialog>("Edit Committee", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadCommitteesAsync();
        }
    }

    private async Task DeleteCommitteeAsync(Committee committee)
    {
        if (committee.MemberCommittees.Count > 0)
        {
            Snackbar.Add($"{committee.MemberCommittees.Count} members are in this committee. Remove them first.", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Message)] = $"Delete the committee \"{committee.Name}\"?",
            [nameof(ConfirmDialog.ConfirmText)] = "Delete",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Committee", parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        try
        {
            await SettingsService.DeleteCommitteeAsync(committee.CommitteeId);
            Snackbar.Add("Committee deleted.", Severity.Success);
            await LoadCommitteesAsync();
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Warning);
        }
    }

    private async Task LoadCommitteesAsync()
    {
        _committees = await SettingsService.GetCommitteesAsync();
    }

    private async Task<string> SaveLogoAsync(IBrowserFile file, string? existingLogoPath)
    {
        var extension = Path.GetExtension(file.Name);
        var logoDirectory = Path.Combine(FileSystem.AppDataDirectory, "Logo");
        Directory.CreateDirectory(logoDirectory);

        var fileName = $"org-logo-{DateTime.Now:yyyyMMddHHmmssfff}{extension}";
        var fullPath = Path.Combine(logoDirectory, fileName);

        await using (var stream = file.OpenReadStream(5 * 1024 * 1024))
        await using (var target = File.Create(fullPath))
        {
            await stream.CopyToAsync(target);
        }

        if (!string.IsNullOrWhiteSpace(existingLogoPath) &&
            File.Exists(existingLogoPath) &&
            !string.Equals(existingLogoPath, fullPath, StringComparison.OrdinalIgnoreCase))
        {
            File.Delete(existingLogoPath);
        }

        return fullPath;
    }

    private string GetLogoStatusText()
    {
        if (_selectedLogoFile is not null)
        {
            return $"Selected: {_selectedLogoFile.Name}";
        }

        return string.IsNullOrWhiteSpace(_existingLogoPath)
            ? "No logo uploaded."
            : $"Current: {Path.GetFileName(_existingLogoPath)}";
    }

    private static string DisplayValue(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value.Trim();
}
