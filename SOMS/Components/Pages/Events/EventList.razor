@page "/events"
@layout MainLayout
@inject EventService EventService
@inject MemberService MemberService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Events</PageTitle>

<MudStack Spacing="3">
    <div class="members-page-header">
        <PageHeader Title="Events" Subtitle="Manage organization events and track attendance" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => OpenAddEditDialogAsync())">
            + Add Event
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <LoadingSpinner />
    }
    else
    {
        <MudPaper Elevation="0" Style="border-bottom: 1px solid #E2E8F0;">
            <MudTabs Rounded="false">
                <MudTabPanel Text="Upcoming">
                    @RenderEventCards(UpcomingEvents, "No upcoming events scheduled.")
                </MudTabPanel>
                <MudTabPanel Text="Past">
                    @RenderEventCards(PastEvents, "No past events available yet.")
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    }
</MudStack>

@code {
    private List<Event> _events = [];
    private int _activeMemberCount;
    private bool _isLoading = true;

    private IEnumerable<Event> UpcomingEvents => _events.Where(eventItem => eventItem.EventDate.Date >= DateTime.Today);
    private IEnumerable<Event> PastEvents => _events.Where(eventItem => eventItem.EventDate.Date < DateTime.Today);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var eventsTask = EventService.GetAllAsync();
        var activeMembersTask = MemberService.GetAllAsync(null, "Active", null, null);

        await Task.WhenAll(eventsTask, activeMembersTask);

        _events = await eventsTask;
        _activeMemberCount = (await activeMembersTask).Count;
        _isLoading = false;
    }

    private async Task OpenAddEditDialogAsync(int? eventId = null)
    {
        var parameters = new DialogParameters
        {
            [nameof(AddEditEventDialog.EventId)] = eventId
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditEventDialog>(
            eventId.HasValue ? "Edit Event" : "Add Event",
            parameters,
            options);

        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    private void RecordAttendance(int eventId)
    {
        NavigationManager.NavigateTo($"/events/{eventId}/attendance");
    }

    private async Task ConfirmDeleteAsync(Event eventItem)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Message)] = $"Delete the event \"{eventItem.Title}\" scheduled on {eventItem.EventDate:MMMM dd, yyyy}?",
            [nameof(ConfirmDialog.ConfirmText)] = "Delete",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Event", parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        await EventService.DeleteAsync(eventItem.EventId);
        Snackbar.Add("Event deleted.", Severity.Success);
        await LoadAsync();
    }

    private RenderFragment RenderEventCards(IEnumerable<Event> events, string emptyMessage) => @<div>
        @if (!events.Any())
        {
            <EmptyState Message="@emptyMessage" Icon="@Icons.Material.Filled.EventBusy" />
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var eventItem in events)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Class="event-card" Elevation="0" Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                            <MudCardContent Class="event-card-header">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Color="@GetEventTypeColor(eventItem.EventType)">
                                        @eventItem.EventType
                                    </MudChip>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @eventItem.EventDate.ToString("MMMM dd, yyyy")
                                    </MudText>
                                </MudStack>
                            </MudCardContent>

                            <MudDivider />

                            <MudCardContent Class="event-card-body">
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">@eventItem.Title</MudText>

                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@DisplayValue(eventItem.Venue)</MudText>
                                    </MudStack>

                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="event-card-description">
                                        @DisplayValue(eventItem.Description)
                                    </MudText>
                                </MudStack>
                            </MudCardContent>

                            <MudDivider />

                            <MudCardActions Class="event-card-footer">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @GetPresentCount(eventItem) / @_activeMemberCount present
                                </MudText>

                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               Size="Size.Small"
                                               OnClick="@(() => RecordAttendance(eventItem.EventId))">
                                        Record Attendance
                                    </MudButton>
                                    <MudTooltip Text="Edit event">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => OpenAddEditDialogAsync(eventItem.EventId))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Delete event">
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                       Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => ConfirmDeleteAsync(eventItem))" />
                                    </MudTooltip>
                                </MudStack>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </div>;

    private static int GetPresentCount(Event eventItem)
        => eventItem.Attendances.Count(attendance => attendance.Status == "Present");

    private static string DisplayValue(string? value)
        => string.IsNullOrWhiteSpace(value) ? "\u2014" : value;

    private static Color GetEventTypeColor(string eventType)
        => eventType switch
        {
            "General Assembly" => Color.Primary,
            "Seminar" => Color.Info,
            "Activity" => Color.Success,
            _ => Color.Default
        };
}
