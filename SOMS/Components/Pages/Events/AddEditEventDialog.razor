@using System.ComponentModel.DataAnnotations
@inject EventService EventService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudForm @ref="_form" Model="_model">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Event Title*"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      For="@(() => _model.Title)"
                                      @bind-Value="_model.Title"
                                      Required="true"
                                      RequiredError="Event title is required." />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudSelect T="string"
                                   Label="Event Type*"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   @bind-Value="_model.EventType">
                            @foreach (var eventType in EventTypes)
                            {
                                <MudSelectItem T="string" Value="@eventType">@eventType</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Event Date*"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Date="_model.EventDate"
                                       DateChanged="OnEventDateChanged" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Venue"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      @bind-Value="_model.Venue" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Description"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="3"
                                      @bind-Value="_model.Description" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel" Disabled="_isSaving">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_isSaving || _isLoading">
            @if (_isSaving)
            {
                <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                <span>Saving...</span>
            }
            else
            {
                <span>Save Event</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private static readonly string[] EventTypes = ["General Assembly", "Seminar", "Activity", "Other"];

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public int? EventId { get; set; }

    private MudForm? _form;
    private Event? _existingEvent;
    private EventFormModel _model = new();
    private bool _isLoading = true;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        if (EventId.HasValue)
        {
            _existingEvent = await EventService.GetByIdAsync(EventId.Value);
            if (_existingEvent is null)
            {
                Snackbar.Add("Event not found.", Severity.Error);
                MudDialog.Cancel();
                return;
            }

            _model = new EventFormModel
            {
                Title = _existingEvent.Title,
                EventType = _existingEvent.EventType,
                EventDate = _existingEvent.EventDate,
                Venue = _existingEvent.Venue,
                Description = _existingEvent.Description
            };
        }

        _isLoading = false;
    }

    private bool IsValidDate => _model.EventDate.HasValue;

    private void OnEventDateChanged(DateTime? value)
    {
        _model.EventDate = value;
    }

    private async Task SaveAsync()
    {
        if (_isSaving || _isLoading || _form is null)
        {
            return;
        }

        await _form.ValidateAsync();
        if (!_form.IsValid || !IsValidDate)
        {
            if (!IsValidDate)
            {
                Snackbar.Add("Event date is required.", Severity.Warning);
            }

            return;
        }

        _isSaving = true;

        try
        {
            var eventItem = new Event
            {
                EventId = EventId ?? 0,
                Title = _model.Title,
                EventType = _model.EventType,
                EventDate = _model.EventDate!.Value,
                Venue = NormalizeOptional(_model.Venue),
                Description = NormalizeOptional(_model.Description),
                CreatedAt = _existingEvent?.CreatedAt ?? DateTime.UtcNow,
                CreatedBy = _existingEvent?.CreatedBy
            };

            if (EventId.HasValue)
            {
                await EventService.UpdateAsync(eventItem);
                Snackbar.Add("Event updated.", Severity.Success);
            }
            else
            {
                await EventService.CreateAsync(eventItem);
                Snackbar.Add("Event created.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private static string? NormalizeOptional(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class EventFormModel
    {
        [Required(ErrorMessage = "Event title is required.")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "Event type is required.")]
        public string EventType { get; set; } = "General Assembly";

        [Required(ErrorMessage = "Event date is required.")]
        public DateTime? EventDate { get; set; } = DateTime.Today;

        public string? Venue { get; set; }

        public string? Description { get; set; }
    }
}
