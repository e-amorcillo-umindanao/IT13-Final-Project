@page "/events/{EventId:int}/attendance"
@layout MainLayout
@inject EventService EventService
@inject AttendanceService AttendanceService
@inject MemberService MemberService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Record Attendance</PageTitle>

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_event is null)
{
    <EmptyState Message="Event not found." Icon="@Icons.Material.Filled.EventBusy" />
}
else
{
    <MudStack Spacing="3">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="GoBack">
            Back
        </MudButton>

        <PageHeader Title="@_event.Title" Subtitle="@_event.EventDate.ToString("MMMM dd, yyyy")" />

        <MudStack Row="true" Spacing="1" Class="attendance-summary-bar">
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">Present: @PresentCount</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Error">Absent: @AbsentCount</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">Excused: @ExcusedCount</MudChip>
            <MudChip T="string" Variant="Variant.Filled" Color="Color.Info">Total: @_rows.Count</MudChip>
        </MudStack>

        <MudPaper Class="members-filter-bar" Elevation="0">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="attendance-actions-bar">
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="@(() => MarkAll("Present"))">
                        Mark All Present
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => MarkAll("Absent"))">
                        Mark All Absent
                    </MudButton>
                </MudStack>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAttendanceAsync" Disabled="_isSaving">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Attendance</span>
                    }
                </MudButton>
            </MudStack>
        </MudPaper>

        <MudPaper Class="members-table-shell" Elevation="0">
            <MudTable T="AttendanceEntryRow"
                      Items="_rows"
                      Hover="true"
                      Dense="true"
                      RowsPerPage="20"
                      Breakpoint="Breakpoint.Sm"
                      Elevation="0"
                      Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                <HeaderContent>
                    <MudTh>Member Name</MudTh>
                    <MudTh>Student ID</MudTh>
                    <MudTh>Attendance Status</MudTh>
                    <MudTh>Committee</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Member Name">@context.Member.FullName</MudTd>
                    <MudTd DataLabel="Student ID">@context.Member.StudentId</MudTd>
                    <MudTd DataLabel="Attendance Status">
                        <MudSelect T="string"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Dense="true"
                                   Value="context.Status"
                                   ValueChanged="@(value => OnStatusChanged(context, value))">
                            <MudSelectItem T="string" Value="@("Present")">Present</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Absent")">Absent</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Excused")">Excused</MudSelectItem>
                        </MudSelect>
                    </MudTd>
                    <MudTd DataLabel="Committee">@GetCommitteeNames(context.Member)</MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-4">
                        <EmptyState Message="No active members available for attendance recording." Icon="@Icons.Material.Filled.GroupOff" />
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager PageSizeOptions="_pageSizeOptions" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudStack>
}

@code {
    [Parameter]
    public int EventId { get; set; }

    private readonly int[] _pageSizeOptions = [10, 20, 50];
    private Event? _event;
    private List<AttendanceEntryRow> _rows = [];
    private bool _isLoading = true;
    private bool _isSaving;

    private int PresentCount => _rows.Count(row => row.Status == "Present");
    private int AbsentCount => _rows.Count(row => row.Status == "Absent");
    private int ExcusedCount => _rows.Count(row => row.Status == "Excused");

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        await LoadAsync();
        _isLoading = false;
    }

    private async Task LoadAsync()
    {
        var eventTask = EventService.GetByIdAsync(EventId);
        var membersTask = MemberService.GetAllAsync(null, "Active", null, null);
        var attendanceTask = AttendanceService.GetByEventAsync(EventId);

        await Task.WhenAll(eventTask, membersTask, attendanceTask);

        _event = await eventTask;
        var members = await membersTask;
        var attendances = await attendanceTask;
        var attendanceLookup = attendances.ToDictionary(attendance => attendance.MemberId, attendance => attendance.Status);

        _rows = members
            .Select(member => new AttendanceEntryRow
            {
                Member = member,
                Status = attendanceLookup.TryGetValue(member.MemberId, out var status) ? status : "Absent"
            })
            .ToList();
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/events");
    }

    private void MarkAll(string status)
    {
        foreach (var row in _rows)
        {
            row.Status = status;
        }
    }

    private void OnStatusChanged(AttendanceEntryRow row, string value)
    {
        row.Status = value;
    }

    private async Task SaveAttendanceAsync()
    {
        if (_isSaving)
        {
            return;
        }

        _isSaving = true;

        try
        {
            var records = _rows
                .Select(row => (row.Member.MemberId, row.Status))
                .ToList();

            await AttendanceService.BulkRecordAsync(EventId, records);
            Snackbar.Add($"Attendance saved for {records.Count} members.", Severity.Success);
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static string GetCommitteeNames(Member member)
    {
        var committeeNames = member.MemberCommittees
            .Select(memberCommittee => memberCommittee.Committee?.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .OrderBy(name => name)
            .ToList();

        return committeeNames.Count == 0 ? "-" : string.Join(", ", committeeNames!);
    }

    private sealed class AttendanceEntryRow
    {
        public Member Member { get; set; } = null!;
        public string Status { get; set; } = "Absent";
    }
}
