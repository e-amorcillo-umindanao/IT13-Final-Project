@page "/members"
@layout MainLayout
@inject MemberService MemberService
@inject EngagementService EngagementService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Members</PageTitle>

<MudStack Spacing="3">
    <div class="members-page-header">
        <PageHeader Title="Members" Subtitle="Manage your organization's members" />

        <MudStack Row="true" Spacing="2" Class="members-header-actions">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Upload"
                       OnClick="OpenImportDialogAsync">
                Import CSV
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="OpenAddMemberDialogAsync">
                + Add Member
            </MudButton>
        </MudStack>
    </div>

    <MudPaper Class="members-filter-bar" Elevation="0">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Value="_searchQuery"
                              ValueChanged="OnSearchChangedAsync"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              DebounceInterval="300" />
            </MudItem>
            <MudItem xs="12" sm="4" md="3">
                <MudSelect T="string"
                           Label="Status"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="_statusFilter"
                           ValueChanged="OnStatusChangedAsync">
                    <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Active")">Active</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Inactive")">Inactive</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Alumni")">Alumni</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <MudSelect T="string"
                           Label="Committee"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="_committeeFilter"
                           ValueChanged="OnCommitteeChangedAsync">
                    <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                    @foreach (var committee in _committees)
                    {
                        <MudSelectItem T="string" Value="@committee.CommitteeId.ToString()">@committee.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" md="3">
                <MudSelect T="string"
                           Label="Stage"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="_stageFilter"
                           ValueChanged="OnStageChangedAsync">
                    <MudSelectItem T="string" Value="@string.Empty">All</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Prospect")">Prospect</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Applicant")">Applicant</MudSelectItem>
                    <MudSelectItem T="string" Value="@("Member")">Member</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="members-table-shell" Elevation="0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudTable Items="_members"
                      Elevation="0"
                      Dense="true"
                      Hover="true"
                      Striped="false"
                      RowsPerPage="20"
                      Breakpoint="Breakpoint.Sm"
                      Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Student ID</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Committee(s)</MudTh>
                    <MudTh>Stage</MudTh>
                    <MudTh>Engagement</MudTh>
                    <MudTh Class="member-actions-cell">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.FirstName @context.LastName</MudTd>
                    <MudTd DataLabel="Student ID">@context.StudentId</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small"
                                 Color="@GetStatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Committee(s)">@GetCommitteeNames(context)</MudTd>
                    <MudTd DataLabel="Stage">
                        <MudChip T="string"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small"
                                 Color="@GetStageColor(context.RecruitmentStage)">
                            @context.RecruitmentStage
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Engagement">
                        <EngagementBadge Score="@GetEngagementScore(context)" />
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <div class="member-actions-cell">
                        <MudTooltip Text="Edit">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenEditDialogAsync(context.MemberId))" />
                        </MudTooltip>
                        <MudTooltip Text="View">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           OnClick="@(() => ViewMember(context.MemberId))" />
                        </MudTooltip>
                        <MudTooltip Text="Remove">
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => ConfirmDeleteAsync(context))" />
                        </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-4">
                        <EmptyState Message="No members matched your filters." Icon="@Icons.Material.Filled.GroupOff" />
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager PageSizeOptions="_pageSizeOptions" />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>
</MudStack>

@code {
    private readonly int[] _pageSizeOptions = [10, 20, 50];
    private List<Member> _members = [];
    private List<Committee> _committees = [];
    private Dictionary<int, int> _engagementScores = [];
    private string? _searchQuery;
    private string? _statusFilter;
    private string? _committeeFilter;
    private string? _stageFilter;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _committees = await MemberService.GetCommitteesAsync();
        await LoadMembersAsync();
    }

    private async Task LoadMembersAsync()
    {
        _isLoading = true;
        var membersTask = MemberService.GetAllAsync(_searchQuery, _statusFilter, _committeeFilter, _stageFilter);
        var engagementTask = EngagementService.GetEngagementSummaryAsync();

        await Task.WhenAll(membersTask, engagementTask);

        _members = await membersTask;
        _engagementScores = (await engagementTask).ToDictionary(row => row.MemberId, row => row.Score);
        _isLoading = false;
    }

    private async Task OnSearchChangedAsync(string value)
    {
        _searchQuery = value;
        await LoadMembersAsync();
    }

    private async Task OnStatusChangedAsync(string value)
    {
        _statusFilter = value;
        await LoadMembersAsync();
    }

    private async Task OnCommitteeChangedAsync(string value)
    {
        _committeeFilter = value;
        await LoadMembersAsync();
    }

    private async Task OnStageChangedAsync(string value)
    {
        _stageFilter = value;
        await LoadMembersAsync();
    }

    private async Task OpenAddMemberDialogAsync()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditMemberDialog>("Add Member", options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadMembersAsync();
        }
    }

    private async Task OpenEditDialogAsync(int memberId)
    {
        var parameters = new DialogParameters
        {
            [nameof(AddEditMemberDialog.MemberId)] = memberId
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddEditMemberDialog>("Edit Member", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadMembersAsync();
        }
    }

    private async Task OpenImportDialogAsync()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ImportMembersDialog>("Import Members", options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadMembersAsync();
        }
    }

    private void ViewMember(int memberId)
    {
        NavigationManager.NavigateTo($"/members/{memberId}");
    }

    private async Task ConfirmDeleteAsync(Member member)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Message)] = $"Are you sure you want to remove {member.FirstName} {member.LastName}? Their interaction history will be preserved.",
            [nameof(ConfirmDialog.ConfirmText)] = "Remove",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Remove Member", parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        await MemberService.SoftDeleteAsync(member.MemberId);
        Snackbar.Add("Member removed.", Severity.Success);
        await LoadMembersAsync();
    }

    private static string GetCommitteeNames(Member member)
    {
        var committeeNames = member.MemberCommittees
            .Select(memberCommittee => memberCommittee.Committee?.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .OrderBy(name => name)
            .ToList();

        return committeeNames.Count == 0 ? "-" : string.Join(", ", committeeNames!);
    }

    private int GetEngagementScore(Member member)
    {
        return _engagementScores.TryGetValue(member.MemberId, out var score) ? score : 0;
    }

    private static Color GetStatusColor(string status)
        => status switch
        {
            "Active" => Color.Success,
            "Alumni" => Color.Info,
            _ => Color.Default
        };

    private static Color GetStageColor(string stage)
        => stage switch
        {
            "Prospect" => Color.Warning,
            "Applicant" => Color.Info,
            "Member" => Color.Success,
            _ => Color.Default
        };
}
