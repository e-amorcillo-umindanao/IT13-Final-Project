@using System.Text
@inject MemberService MemberService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Upload a CSV file using the SOMS member template. Duplicate student IDs will be skipped automatically.
            </MudText>

            <div class="member-import-input">
                <InputFile OnChange="HandleFileSelected" accept=".csv" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_selectedFileName))
            {
                <MudText Typo="Typo.body2">Selected file: @_selectedFileName</MudText>
            }

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="DownloadTemplateAsync">
                Download Template
            </MudButton>

            @if (!string.IsNullOrWhiteSpace(_resultMessage))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                    @_resultMessage
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Close">Close</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ImportAsync" Disabled="_selectedFile is null || _isImporting">
            @if (_isImporting)
            {
                <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                <span>Importing...</span>
            }
            else
            {
                <span>Import</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private IBrowserFile? _selectedFile;
    private string? _selectedFileName;
    private string? _resultMessage;
    private bool _isImporting;

    private Task HandleFileSelected(InputFileChangeEventArgs args)
    {
        _selectedFile = args.File;
        _selectedFileName = _selectedFile?.Name;
        _resultMessage = null;
        return Task.CompletedTask;
    }

    private async Task DownloadTemplateAsync()
    {
        var template = "StudentId,FirstName,LastName,Email,PhoneNumber,Address,Status,RecruitmentStage,JoinDate\r\n" +
                       "2024-0001,Juan,Cruz,juan.cruz@example.com,09171234567,Davao City,Active,Member,2026-03-23\r\n";

        await using var stream = new MemoryStream(Encoding.UTF8.GetBytes(template));
        using var streamReference = new DotNetStreamReference(stream);
        await JSRuntime.InvokeVoidAsync("somsFileDownload.downloadFileFromStream", "members-template.csv", streamReference);
    }

    private async Task ImportAsync()
    {
        if (_selectedFile is null || _isImporting)
        {
            return;
        }

        _isImporting = true;

        try
        {
            await using var stream = _selectedFile.OpenReadStream(5 * 1024 * 1024);
            var (imported, skipped) = await MemberService.ImportFromCsvAsync(stream);
            _resultMessage = $"Imported: {imported} members. Skipped: {skipped} duplicates.";
            Snackbar.Add(_resultMessage, Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception exception)
        {
            Snackbar.Add($"CSV import failed: {exception.Message}", Severity.Error);
        }
        finally
        {
            _isImporting = false;
        }
    }

    private void Close() => MudDialog.Cancel();
}
