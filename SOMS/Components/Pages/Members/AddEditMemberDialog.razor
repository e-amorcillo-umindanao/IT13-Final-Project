@using System.ComponentModel.DataAnnotations
@inject MemberService MemberService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudForm @ref="_form" Model="_model">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="First Name*"
                                      Variant="Variant.Outlined"
                                      For="@(() => _model.FirstName)"
                                      @bind-Value="_model.FirstName"
                                      Required="true"
                                      RequiredError="First name is required." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Last Name*"
                                      Variant="Variant.Outlined"
                                      For="@(() => _model.LastName)"
                                      @bind-Value="_model.LastName"
                                      Required="true"
                                      RequiredError="Last name is required." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Student ID*"
                                      Variant="Variant.Outlined"
                                      For="@(() => _model.StudentId)"
                                      @bind-Value="_model.StudentId"
                                      Required="true"
                                      RequiredError="Student ID is required." />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Email"
                                      Variant="Variant.Outlined"
                                      For="@(() => _model.Email)"
                                      @bind-Value="_model.Email" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      Label="Phone Number"
                                      Variant="Variant.Outlined"
                                      @bind-Value="_model.PhoneNumber" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudDatePicker Label="Join Date*"
                                       Variant="Variant.Outlined"
                                       Date="_model.JoinDate"
                                       DateChanged="OnJoinDateChanged" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Address"
                                      Variant="Variant.Outlined"
                                      Lines="2"
                                      @bind-Value="_model.Address" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string"
                                   Label="Status*"
                                   Variant="Variant.Outlined"
                                   @bind-Value="_model.Status">
                            <MudSelectItem T="string" Value="@("Active")">Active</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Inactive")">Inactive</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Alumni")">Alumni</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect T="string"
                                   Label="Recruitment Stage*"
                                   Variant="Variant.Outlined"
                                   @bind-Value="_model.RecruitmentStage">
                            <MudSelectItem T="string" Value="@("Prospect")">Prospect</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Applicant")">Applicant</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Member")">Member</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2">Committee Assignment</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            Assign committees now or update them later from the member profile.
                        </MudText>

                        @if (_committeeAssignments.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                                No committees assigned yet.
                            </MudText>
                        }
                        else
                        {
                            <MudStack Spacing="1" Class="mb-3">
                                @foreach (var assignment in _committeeAssignments.OrderBy(item => item.CommitteeName))
                                {
                                    <MudPaper Class="member-committee-row pa-3" Elevation="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                            <div>
                                                <MudText Typo="Typo.body1">@assignment.CommitteeName</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                    @(string.IsNullOrWhiteSpace(assignment.CommitteeRole) ? "No role specified" : assignment.CommitteeRole)
                                                </MudText>
                                            </div>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => RemoveCommitteeAssignment(assignment.CommitteeId))" />
                                        </MudStack>
                                    </MudPaper>
                                }
                            </MudStack>
                        }

                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="5">
                                <MudSelect T="int?"
                                           Label="Committee"
                                           Variant="Variant.Outlined"
                                           Value="_selectedCommitteeId"
                                           ValueChanged="OnCommitteeSelectionChanged">
                                    @foreach (var committee in _committees)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)committee.CommitteeId)">@committee.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="5">
                                <MudTextField T="string"
                                              Label="Role"
                                              Variant="Variant.Outlined"
                                              Value="_selectedCommitteeRole"
                                              ValueChanged="OnCommitteeRoleChanged" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           Class="mt-md-1"
                                           OnClick="AddCommitteeAssignment">
                                    Assign
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_isSaving">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_isSaving || _isLoading">
            @if (_isSaving)
            {
                <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                <span>Saving...</span>
            }
            else
            {
                <span>Save</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public int? MemberId { get; set; }

    private MudForm? _form;
    private MemberFormModel _model = new();
    private Member? _existingMember;
    private List<Committee> _committees = [];
    private List<CommitteeAssignmentItem> _committeeAssignments = [];
    private List<CommitteeAssignmentItem> _originalCommitteeAssignments = [];
    private int? _selectedCommitteeId;
    private string? _selectedCommitteeRole;
    private bool _isLoading = true;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        _committees = await MemberService.GetCommitteesAsync();

        if (MemberId.HasValue)
        {
            _existingMember = await MemberService.GetByIdAsync(MemberId.Value);
            if (_existingMember is null)
            {
                Snackbar.Add("Member not found.", Severity.Error);
                MudDialog.Cancel();
                return;
            }

            _model = new MemberFormModel
            {
                FirstName = _existingMember.FirstName,
                LastName = _existingMember.LastName,
                StudentId = _existingMember.StudentId,
                Email = _existingMember.Email,
                PhoneNumber = _existingMember.PhoneNumber,
                Address = _existingMember.Address,
                Status = _existingMember.Status,
                RecruitmentStage = _existingMember.RecruitmentStage,
                JoinDate = _existingMember.JoinDate
            };

            _committeeAssignments = _existingMember.MemberCommittees
                .Select(memberCommittee => new CommitteeAssignmentItem
                {
                    MemberCommitteeId = memberCommittee.MemberCommitteeId,
                    CommitteeId = memberCommittee.CommitteeId,
                    CommitteeName = memberCommittee.Committee.Name,
                    CommitteeRole = memberCommittee.CommitteeRole
                })
                .OrderBy(item => item.CommitteeName)
                .ToList();

            _originalCommitteeAssignments = _committeeAssignments
                .Select(item => item.Clone())
                .ToList();
        }

        _isLoading = false;
    }

    private bool IsValidDate => _model.JoinDate.HasValue;

    private void OnJoinDateChanged(DateTime? value)
    {
        _model.JoinDate = value;
    }

    private void OnCommitteeSelectionChanged(int? value)
    {
        _selectedCommitteeId = value;
    }

    private void OnCommitteeRoleChanged(string? value)
    {
        _selectedCommitteeRole = value;
    }

    private void AddCommitteeAssignment()
    {
        if (!_selectedCommitteeId.HasValue)
        {
            Snackbar.Add("Select a committee first.", Severity.Warning);
            return;
        }

        var committee = _committees.FirstOrDefault(item => item.CommitteeId == _selectedCommitteeId.Value);
        if (committee is null)
        {
            Snackbar.Add("Selected committee could not be found.", Severity.Error);
            return;
        }

        var existingAssignment = _committeeAssignments.FirstOrDefault(item => item.CommitteeId == committee.CommitteeId);
        if (existingAssignment is not null)
        {
            existingAssignment.CommitteeRole = NormalizeOptional(_selectedCommitteeRole);
        }
        else
        {
            _committeeAssignments.Add(new CommitteeAssignmentItem
            {
                CommitteeId = committee.CommitteeId,
                CommitteeName = committee.Name,
                CommitteeRole = NormalizeOptional(_selectedCommitteeRole)
            });
        }

        _selectedCommitteeId = null;
        _selectedCommitteeRole = null;
    }

    private void RemoveCommitteeAssignment(int committeeId)
    {
        _committeeAssignments.RemoveAll(item => item.CommitteeId == committeeId);
    }

    private async Task SaveAsync()
    {
        if (_isSaving || _form is null)
        {
            return;
        }

        await _form.ValidateAsync();
        if (!_form.IsValid || !IsValidDate)
        {
            if (!IsValidDate)
            {
                Snackbar.Add("Join Date is required.", Severity.Warning);
            }

            return;
        }

        _isSaving = true;

        try
        {
            var member = new Member
            {
                MemberId = MemberId ?? 0,
                StudentId = _model.StudentId,
                FirstName = _model.FirstName,
                LastName = _model.LastName,
                Email = NormalizeOptional(_model.Email),
                PhoneNumber = NormalizeOptional(_model.PhoneNumber),
                Address = NormalizeOptional(_model.Address),
                Status = _model.Status,
                RecruitmentStage = _model.RecruitmentStage,
                JoinDate = _model.JoinDate!.Value,
                CreatedAt = _existingMember?.CreatedAt ?? DateTime.UtcNow,
                CreatedBy = _existingMember?.CreatedBy,
                IsDeleted = _existingMember?.IsDeleted ?? false
            };

            if (MemberId.HasValue)
            {
                await MemberService.UpdateAsync(member);
            }
            else
            {
                await MemberService.CreateAsync(member);
            }

            await SyncCommitteeAssignmentsAsync(member.MemberId);

            Snackbar.Add("Member saved successfully.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task SyncCommitteeAssignmentsAsync(int memberId)
    {
        var currentCommitteeIds = _committeeAssignments
            .Select(item => item.CommitteeId)
            .ToHashSet();

        foreach (var removedAssignment in _originalCommitteeAssignments
                     .Where(item => item.MemberCommitteeId > 0 && !currentCommitteeIds.Contains(item.CommitteeId)))
        {
            await MemberService.RemoveCommitteeAsync(removedAssignment.MemberCommitteeId);
        }

        foreach (var assignment in _committeeAssignments)
        {
            await MemberService.AssignCommitteeAsync(memberId, assignment.CommitteeId, assignment.CommitteeRole);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private static string? NormalizeOptional(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class CommitteeAssignmentItem
    {
        public int MemberCommitteeId { get; set; }
        public int CommitteeId { get; set; }
        public string CommitteeName { get; set; } = string.Empty;
        public string? CommitteeRole { get; set; }

        public CommitteeAssignmentItem Clone()
        {
            return new CommitteeAssignmentItem
            {
                MemberCommitteeId = MemberCommitteeId,
                CommitteeId = CommitteeId,
                CommitteeName = CommitteeName,
                CommitteeRole = CommitteeRole
            };
        }
    }

    private sealed class MemberFormModel
    {
        [Required(ErrorMessage = "First name is required.")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required.")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Student ID is required.")]
        public string StudentId { get; set; } = string.Empty;

        public string? Email { get; set; }

        public string? PhoneNumber { get; set; }

        public string? Address { get; set; }

        [Required(ErrorMessage = "Status is required.")]
        public string Status { get; set; } = "Active";

        [Required(ErrorMessage = "Recruitment stage is required.")]
        public string RecruitmentStage { get; set; } = "Member";

        [Required(ErrorMessage = "Join date is required.")]
        public DateTime? JoinDate { get; set; } = DateTime.Today;
    }
}
