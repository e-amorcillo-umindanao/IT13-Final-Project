@using System.ComponentModel.DataAnnotations
@inject InteractionService InteractionService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudText Typo="Typo.h6" Class="mb-4">@DialogTitle</MudText>

            <MudForm @ref="_form" Model="_model">
                <MudGrid Spacing="2">
                    @if (!IsMemberLocked)
                    {
                        <MudItem xs="12">
                            <MudAutocomplete T="MemberLookupItem"
                                             Label="Member"
                                             Variant="Variant.Outlined"
                                             Value="_selectedMember"
                                             ValueChanged="OnSelectedMemberChangedAsync"
                                             SearchFunc="SearchMembersAsync"
                                             ToStringFunc="@(member => member?.DisplayName ?? string.Empty)"
                                             Clearable="true"
                                             ResetValueOnEmptyText="true"
                                             CoerceText="false" />
                        </MudItem>
                    }

                    <MudItem xs="12">
                        <MudSelect T="string"
                                   Label="Interaction Type"
                                   Variant="Variant.Outlined"
                                   @bind-Value="_model.InteractionType">
                            @foreach (var interactionType in InteractionTypes)
                            {
                                <MudSelectItem T="string" Value="@interactionType">@interactionType</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12">
                        <MudDatePicker Label="Date"
                                       Variant="Variant.Outlined"
                                       Date="_model.InteractionDate"
                                       DateChanged="OnInteractionDateChanged" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      Label="Notes"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      For="@(() => _model.Notes)"
                                      @bind-Value="_model.Notes"
                                      Required="true"
                                      RequiredError="Notes are required." />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="_isSaving">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="_isSaving || _isLoading">
            @if (_isSaving)
            {
                <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                <span>Saving...</span>
            }
            else
            {
                <span>Save Log</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private static readonly string[] InteractionTypes = ["Call", "Meeting", "Follow-up", "Message", "Visit"];

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public int? MemberId { get; set; }

    [Parameter]
    public int? InteractionLogId { get; set; }

    [Parameter]
    public bool IsMemberLocked { get; set; }

    private MudForm? _form;
    private InteractionFormModel _model = new();
    private List<MemberLookupItem> _members = [];
    private MemberLookupItem? _selectedMember;
    private InteractionLog? _existingInteraction;
    private bool _isLoading = true;
    private bool _isSaving;

    private string DialogTitle
        => $"{(InteractionLogId.HasValue ? "Edit Interaction" : "Log Interaction")}{(_selectedMember is null ? string.Empty : $" - {_selectedMember.FullName}")}";

    protected override async Task OnInitializedAsync()
    {
        _members = await InteractionService.GetMemberOptionsAsync();

        if (InteractionLogId.HasValue)
        {
            _existingInteraction = await InteractionService.GetByIdAsync(InteractionLogId.Value);
            if (_existingInteraction is null)
            {
                Snackbar.Add("Interaction not found.", Severity.Error);
                MudDialog.Cancel();
                return;
            }

            _model = new InteractionFormModel
            {
                InteractionType = _existingInteraction.InteractionType,
                InteractionDate = _existingInteraction.InteractionDate,
                Notes = _existingInteraction.Notes
            };

            MemberId ??= _existingInteraction.MemberId;
        }

        if (MemberId.HasValue)
        {
            _selectedMember = _members.FirstOrDefault(member => member.MemberId == MemberId.Value);
        }

        _isLoading = false;
    }

    private Task<IEnumerable<MemberLookupItem>> SearchMembersAsync(string value, CancellationToken token)
    {
        IEnumerable<MemberLookupItem> results = _members;
        if (!string.IsNullOrWhiteSpace(value))
        {
            var normalizedValue = value.Trim();
            results = results.Where(member =>
                member.FullName.Contains(normalizedValue, StringComparison.OrdinalIgnoreCase) ||
                member.StudentId.Contains(normalizedValue, StringComparison.OrdinalIgnoreCase));
        }

        return Task.FromResult(results);
    }

    private Task OnSelectedMemberChangedAsync(MemberLookupItem? member)
    {
        _selectedMember = member;
        return Task.CompletedTask;
    }

    private void OnInteractionDateChanged(DateTime? value)
    {
        _model.InteractionDate = value;
    }

    private async Task SaveAsync()
    {
        if (_isSaving || _isLoading || _form is null)
        {
            return;
        }

        await _form.ValidateAsync();
        if (!_form.IsValid)
        {
            return;
        }

        if (_selectedMember is null)
        {
            Snackbar.Add("Select a member first.", Severity.Warning);
            return;
        }

        if (!_model.InteractionDate.HasValue)
        {
            Snackbar.Add("Select an interaction date.", Severity.Warning);
            return;
        }

        _isSaving = true;

        try
        {
            var log = new InteractionLog
            {
                InteractionLogId = _existingInteraction?.InteractionLogId ?? 0,
                MemberId = _selectedMember.MemberId,
                InteractionType = _model.InteractionType,
                InteractionDate = _model.InteractionDate.Value,
                Notes = _model.Notes.Trim(),
                CreatedAt = _existingInteraction?.CreatedAt ?? DateTime.UtcNow,
                CreatedBy = _existingInteraction?.CreatedBy
            };

            if (_existingInteraction is null)
            {
                await InteractionService.LogInteractionAsync(log);
                Snackbar.Add("Interaction logged.", Severity.Success);
            }
            else
            {
                await InteractionService.UpdateInteractionAsync(log);
                Snackbar.Add("Interaction updated.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException exception)
        {
            Snackbar.Add(exception.Message, Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private sealed class InteractionFormModel
    {
        [Required(ErrorMessage = "Interaction type is required.")]
        public string InteractionType { get; set; } = "Call";

        [Required(ErrorMessage = "Interaction date is required.")]
        public DateTime? InteractionDate { get; set; } = DateTime.Today;

        [Required(ErrorMessage = "Notes are required.")]
        public string Notes { get; set; } = string.Empty;
    }
}
