@page "/engagement"
@layout MainLayout
@inject EngagementService EngagementService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager

<PageTitle>Engagement</PageTitle>

<MudStack Spacing="3">
    <div class="members-page-header">
        <PageHeader Title="Engagement" Subtitle="Member engagement scores and interaction history" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.AddComment"
                   OnClick="@(() => OpenLogInteractionDialogAsync())">
            + Log Interaction
        </MudButton>
    </div>

    <MudStack Row="true" Spacing="1" Class="engagement-summary-bar">
        <MudChip T="string" Variant="Variant.Filled" Color="Color.Success">High: @HighCount</MudChip>
        <MudChip T="string" Variant="Variant.Filled" Color="Color.Warning">Medium: @MediumCount</MudChip>
        <MudChip T="string" Variant="Variant.Filled" Color="Color.Error">Low: @LowCount</MudChip>
    </MudStack>

    <MudPaper Class="members-filter-bar" Elevation="0">
        <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
            <MudButton Variant="@GetFilterVariant("All")" OnClick="@(() => SetFilter("All"))">All</MudButton>
            <MudButton Variant="@GetFilterVariant("High")" OnClick="@(() => SetFilter("High"))">High</MudButton>
            <MudButton Variant="@GetFilterVariant("Medium")" OnClick="@(() => SetFilter("Medium"))">Medium</MudButton>
            <MudButton Variant="@GetFilterVariant("Low")" OnClick="@(() => SetFilter("Low"))">Low</MudButton>
        </MudButtonGroup>
    </MudPaper>

    <MudPaper Class="members-table-shell" Elevation="0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else
        {
            <MudTable T="EngagementSummaryRow"
                      Items="FilteredRows"
                      Hover="true"
                      Dense="true"
                      RowsPerPage="20"
                      Breakpoint="Breakpoint.Sm"
                      Elevation="0"
                      SortLabel="Sort by"
                      Style="border: 1px solid #E2E8F0; border-radius: 4px;">
                <HeaderContent>
                    <MudTh>
                        <MudTableSortLabel T="EngagementSummaryRow" SortBy="@(row => row.FullName)">Member Name</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="EngagementSummaryRow" SortBy="@(row => row.Score)">Score</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="EngagementSummaryRow" SortBy="@(row => row.Label)">Label</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="EngagementSummaryRow" SortBy="@(row => row.LastInteraction ?? DateTime.MinValue)">Last Interaction</MudTableSortLabel>
                    </MudTh>
                    <MudTh>
                        <MudTableSortLabel T="EngagementSummaryRow" SortBy="@(row => row.InteractionsThisSemester)">Interactions This Semester</MudTableSortLabel>
                    </MudTh>
                    <MudTh Class="member-actions-cell">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Member Name">@context.FullName</MudTd>
                    <MudTd DataLabel="Score">
                        <MudStack Spacing="1" Class="engagement-score-cell">
                            <MudProgressLinear Value="@context.Score" Color="@GetScoreColor(context.Label)" Rounded="true" Class="engagement-progress" />
                            <MudText Typo="Typo.caption">@context.Score / 100</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Label">
                        <EngagementBadge Score="@context.Score" />
                    </MudTd>
                    <MudTd DataLabel="Last Interaction">@FormatDate(context.LastInteraction)</MudTd>
                    <MudTd DataLabel="Interactions This Semester">@context.InteractionsThisSemester</MudTd>
                    <MudTd DataLabel="Actions">
                        <div class="member-actions-cell">
                            <MudTooltip Text="View member">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                               Size="Size.Small"
                                               Color="Color.Default"
                                               OnClick="@(() => ViewMember(context.MemberId))" />
                            </MudTooltip>
                            <MudTooltip Text="Log interaction">
                                <MudIconButton Icon="@Icons.Material.Filled.Message"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="@(() => OpenLogInteractionDialogAsync(context.MemberId))" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="pa-4">
                        <EmptyState Message="No members matched the selected engagement filter." Icon="@Icons.Material.Filled.Forum" />
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager PageSizeOptions="_pageSizeOptions" />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>
</MudStack>

@code {
    private readonly int[] _pageSizeOptions = [10, 20, 50];
    private List<EngagementSummaryRow> _rows = [];
    private string _activeFilter = "All";
    private bool _isLoading = true;

    private IEnumerable<EngagementSummaryRow> FilteredRows => _rows.Where(row =>
        _activeFilter == "All" ||
        string.Equals(row.Label, _activeFilter, StringComparison.OrdinalIgnoreCase));

    private int HighCount => _rows.Count(row => row.Label == "High");
    private int MediumCount => _rows.Count(row => row.Label == "Medium");
    private int LowCount => _rows.Count(row => row.Label == "Low");

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _rows = await EngagementService.GetEngagementSummaryAsync();
        _isLoading = false;
    }

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
    }

    private Variant GetFilterVariant(string filter)
        => string.Equals(_activeFilter, filter, StringComparison.OrdinalIgnoreCase)
            ? Variant.Filled
            : Variant.Outlined;

    private async Task OpenLogInteractionDialogAsync(int? memberId = null)
    {
        var parameters = new DialogParameters
        {
            [nameof(LogInteraction.MemberId)] = memberId,
            [nameof(LogInteraction.IsMemberLocked)] = false
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LogInteraction>("Log Interaction", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadAsync();
        }
    }

    private void ViewMember(int memberId)
    {
        NavigationManager.NavigateTo($"/members/{memberId}");
    }

    private static Color GetScoreColor(string label)
        => label switch
        {
            "High" => Color.Success,
            "Medium" => Color.Warning,
            "Low" => Color.Error,
            _ => Color.Default
        };

    private static string FormatDate(DateTime? value)
        => value.HasValue ? value.Value.ToString("MMM dd, yyyy") : "Never";
}
