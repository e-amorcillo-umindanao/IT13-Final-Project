@page "/dashboard"
@layout MainLayout
@inject ReportService ReportService

<PageTitle>Dashboard</PageTitle>

<MudStack Spacing="3">
    <PageHeader Title="Dashboard" Subtitle="CRM overview and engagement performance" />

    @if (_isLoading)
    {
        <LoadingSpinner />
    }
    else
    {
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6" lg="3" Class="dashboard-animated" Style="--dashboard-delay: 0ms;">
                <KpiCard Title="Total Members"
                         Value="@_kpis.TotalMembers.ToString("N0")"
                         Icon="@Icons.Material.Filled.Group"
                         Color="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3" Class="dashboard-animated" Style="--dashboard-delay: 70ms;">
                <KpiCard Title="Active Members %"
                         Value="@($"{_kpis.ActivePercent:0.#}%")"
                         Icon="@Icons.Material.Filled.TrendingUp"
                         Color="Color.Success" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3" Class="dashboard-animated" Style="--dashboard-delay: 140ms;">
                <KpiCard Title="Upcoming Events"
                         Value="@_kpis.UpcomingEventsCount.ToString("N0")"
                         Icon="@Icons.Material.Filled.Event"
                         Color="Color.Info" />
            </MudItem>
            <MudItem xs="12" sm="6" lg="3" Class="dashboard-animated" Style="--dashboard-delay: 210ms;">
                <KpiCard Title="Low Engagement"
                         Value="@_kpis.LowEngagementCount.ToString("N0")"
                         Icon="@Icons.Material.Filled.Warning"
                         Color="Color.Error" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="3">
            <MudItem xs="12" lg="6">
                <MudCard Class="dashboard-section-card dashboard-card-fill">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">Member Engagement Distribution</MudText>

                            @if (HasEngagementDistributionData)
                            {
                                <MudChart T="double"
                                          ChartType="ChartType.Donut"
                                          ChartSeries="@_engagementDistributionSeries"
                                          ChartLabels="@_engagementDistributionLabels"
                                          ChartOptions="@_engagementChartOptions"
                                          Width="100%"
                                          Height="250px" />
                            }
                            else
                            {
                                <div class="dashboard-chart-empty">
                                    <EmptyState Message="No engagement data available yet." Icon="@Icons.Material.Filled.DonutLarge" />
                                </div>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" lg="6">
                <MudCard Class="dashboard-section-card dashboard-card-fill">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">Attendance Trend - Last 5 Events</MudText>

                            @if (HasAttendanceTrendData)
                            {
                                <MudChart T="double"
                                          ChartType="ChartType.Line"
                                          ChartSeries="@_attendanceTrendSeries"
                                          ChartLabels="@_attendanceTrendLabels"
                                          ChartOptions="@_attendanceTrendOptions"
                                          Width="100%"
                                          Height="250px" />
                            }
                            else
                            {
                                <div class="dashboard-chart-empty">
                                    <EmptyState Message="No past attendance data available yet." Icon="@Icons.Material.Filled.ShowChart" />
                                </div>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <MudCard Class="dashboard-section-card">
            <MudCardContent>
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Recent Interactions</MudText>

                    @if (_recentInteractions.Count == 0)
                    {
                        <EmptyState Message="No interactions have been logged yet." Icon="@Icons.Material.Filled.Forum" />
                    }
                    else
                    {
                        <MudList T="InteractionLog" Dense="true" Class="dashboard-interaction-list">
                            @foreach (var interaction in _recentInteractions)
                            {
                                <MudListItem T="InteractionLog" Class="dashboard-interaction-item">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2" Class="dashboard-interaction-row">
                                        <MudAvatar Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Medium" Class="dashboard-interaction-avatar">
                                            <MudIcon Icon="@GetInteractionIcon(interaction.InteractionType)" Size="Size.Small" />
                                        </MudAvatar>

                                        <MudStack Spacing="1" Class="dashboard-interaction-content">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="dashboard-interaction-heading">
                                                <MudText Typo="Typo.body2">
                                                    [@interaction.InteractionType] with @interaction.Member.FullName
                                                </MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @FormatRelativeTime(interaction.CreatedAt)
                                                </MudText>
                                            </MudStack>

                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @GetNotesPreview(interaction.Notes)
                                            </MudText>
                                        </MudStack>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }

                    <MudStack Row="true" Justify="Justify.FlexEnd">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   Href="/engagement">
                            View all interactions
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudCardContent>
        </MudCard>
    }
</MudStack>

@code {
    private DashboardKpis _kpis = new(0, 0, 0, 0, 0, 0);
    private List<InteractionLog> _recentInteractions = [];
    private List<AttendanceTrendPoint> _attendanceTrend = [];
    private List<ChartSeries<double>> _engagementDistributionSeries = [];
    private List<ChartSeries<double>> _attendanceTrendSeries = [];
    private string[] _engagementDistributionLabels = ["High", "Medium", "Low"];
    private string[] _attendanceTrendLabels = [];
    private readonly ChartOptions _engagementChartOptions = new()
    {
        ShowLegend = true,
        ChartPalette = ["#22C55E", "#F59E0B", "#EF4444"]
    };
    private readonly LineChartOptions _attendanceTrendOptions = new()
    {
        ShowLegend = true,
        ChartPalette = ["#3B82F6"],
        ShowDataMarkers = true,
        YAxisRequireZeroPoint = true,
        YAxisSuggestedMax = 100,
        YAxisFormat = "0'%'",
        MaxNumYAxisTicks = 6
    };
    private bool _isLoading = true;

    private bool HasEngagementDistributionData
        => _engagementDistributionSeries.Count > 0 &&
           _engagementDistributionSeries[0].Data.Any(value => value > 0);

    private bool HasAttendanceTrendData
        => _attendanceTrend.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        var kpiTask = ReportService.GetDashboardKpisAsync();
        var trendTask = ReportService.GetAttendanceTrendAsync();
        var recentInteractionsTask = ReportService.GetRecentInteractionsAsync();

        await Task.WhenAll(kpiTask, trendTask, recentInteractionsTask);

        _kpis = await kpiTask;
        _attendanceTrend = await trendTask;
        _recentInteractions = await recentInteractionsTask;

        _engagementDistributionSeries =
        [
            new ChartSeries<double>
            {
                Name = "Members",
                Data = new[]
                {
                    (double)_kpis.HighEngagementCount,
                    _kpis.MediumEngagementCount,
                    _kpis.LowEngagementCount
                }
            }
        ];

        _attendanceTrendLabels = _attendanceTrend
            .Select(point => ShortenEventTitle(point.EventTitle))
            .ToArray();

        _attendanceTrendSeries =
        [
            new ChartSeries<double>
            {
                Name = "Attendance Rate",
                Data = _attendanceTrend
                    .Select(point => Math.Round(point.AttendanceRate * 100, 1))
                    .ToArray()
            }
        ];

        _isLoading = false;
    }

    private static string ShortenEventTitle(string title)
    {
        var normalized = title.Trim();
        return normalized.Length <= 18 ? normalized : $"{normalized[..15]}...";
    }

    private static string GetInteractionIcon(string interactionType)
        => interactionType switch
        {
            "Call" => Icons.Material.Filled.Call,
            "Email" => Icons.Material.Filled.Email,
            "Message" => Icons.Material.Filled.Chat,
            "Meeting" => Icons.Material.Filled.Groups,
            "Visit" => Icons.Material.Filled.Place,
            _ => Icons.Material.Filled.Forum
        };

    private static string GetNotesPreview(string notes)
    {
        var normalized = string.IsNullOrWhiteSpace(notes) ? "No notes provided." : notes.Trim();
        return normalized.Length <= 60 ? normalized : $"{normalized[..57]}...";
    }

    private static string FormatRelativeTime(DateTime dateTime)
    {
        var elapsed = DateTime.UtcNow - dateTime.ToUniversalTime();
        if (elapsed < TimeSpan.Zero)
        {
            elapsed = TimeSpan.Zero;
        }

        if (elapsed.TotalMinutes < 1)
        {
            return "just now";
        }

        if (elapsed.TotalHours < 1)
        {
            var minutes = Math.Max(1, (int)Math.Floor(elapsed.TotalMinutes));
            return $"{minutes} min{(minutes == 1 ? string.Empty : "s")} ago";
        }

        if (elapsed.TotalDays < 1)
        {
            var hours = Math.Max(1, (int)Math.Floor(elapsed.TotalHours));
            return $"{hours} hr{(hours == 1 ? string.Empty : "s")} ago";
        }

        if (elapsed.TotalDays < 30)
        {
            var days = Math.Max(1, (int)Math.Floor(elapsed.TotalDays));
            return $"{days} day{(days == 1 ? string.Empty : "s")} ago";
        }

        var months = Math.Max(1, (int)Math.Floor(elapsed.TotalDays / 30));
        return $"{months} mo{(months == 1 ? string.Empty : "s")} ago";
    }
}
