@page "/login"
@layout AuthLayout
@inject AuthService AuthService
@inject NavigationManager NavManager

<PageTitle>Login</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall"
              Class="auth-page d-flex align-center justify-center"
              Style="min-height: 100vh;">
    <MudCard Class="login-card">
        <MudCardContent Class="pa-6">
            <MudStack Spacing="3">
                <MudStack Spacing="1" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h5" Align="Align.Center" Class="fw-bold">SOMS</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        Student Organization Management System
                    </MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                        Invalid username or password.
                    </MudAlert>
                }

                <MudTextField T="string"
                              Label="Username"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              @bind-Value="_username" />

                <MudTextField T="string"
                              Label="Password"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              InputType="@PasswordInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@PasswordAdornmentIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              @bind-Value="_password" />

                <MudButton FullWidth="true"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_isBusy"
                           OnClick="HandleLoginAsync">
                    @if (_isBusy)
                    {
                        <MudProgressCircular Class="me-2" Color="Color.Inherit" Indeterminate="true" Size="Size.Small" />
                        <span>Authenticating...</span>
                    }
                    else
                    {
                        <span>LOGIN</span>
                    }
                </MudButton>

                <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
                    University of Mindanao
                </MudText>
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string? _errorMessage;
    private bool _isBusy;
    private bool _showPassword;

    private InputType PasswordInputType => _showPassword ? InputType.Text : InputType.Password;
    private string PasswordAdornmentIcon => _showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && AuthService.IsAuthenticated)
        {
            NavManager.NavigateTo("/dashboard");
        }
    }

    private async Task HandleLoginAsync()
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;
        _errorMessage = null;

        var isAuthenticated = await AuthService.LoginAsync(_username.Trim(), _password);
        if (isAuthenticated)
        {
            NavManager.NavigateTo("/dashboard");
        }
        else
        {
            _errorMessage = "Invalid username or password.";
        }

        _isBusy = false;
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }
}
