@inject AuthService AuthService
@inject IDialogService DialogService
@inject InteractionService InteractionService
@inject ISnackbar Snackbar

@if (OrderedInteractions.Count == 0)
{
    <EmptyState Message="No interactions logged yet." Icon="@Icons.Material.Filled.Forum" />
}
else
{
    <div class="interaction-timeline">
        @foreach (var interaction in OrderedInteractions)
        {
            <div class="interaction-timeline-item">
                <div class="interaction-timeline-marker">
                    <div class="interaction-timeline-icon">
                        <MudIcon Icon="@GetInteractionIcon(interaction.InteractionType)" Color="@GetInteractionColor(interaction.InteractionType)" />
                    </div>
                </div>

                <MudPaper Class="interaction-timeline-card pa-4" Elevation="0">
                    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">@interaction.InteractionDate.ToString("MMM dd, yyyy")</MudText>
                            <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Color="@GetInteractionColor(interaction.InteractionType)">
                                @interaction.InteractionType
                            </MudChip>
                        </MudStack>

                        @if (CanManageInteractions)
                        {
                            <MudStack Row="true" Spacing="0">
                                <MudTooltip Text="Edit interaction">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => OpenEditDialogAsync(interaction))" />
                                </MudTooltip>
                                <MudTooltip Text="Delete interaction">
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => ConfirmDeleteAsync(interaction))" />
                                </MudTooltip>
                            </MudStack>
                        }
                    </MudStack>

                    <MudText Typo="Typo.body2" Color="Color.Secondary">@interaction.Notes</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                        Logged by @(interaction.CreatedByUser?.Username ?? "Unknown")
                    </MudText>
                </MudPaper>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public List<InteractionLog> Interactions { get; set; } = [];

    [Parameter]
    public bool LockMemberSelection { get; set; } = true;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private bool CanManageInteractions => AuthService.CurrentRole is "Admin" or "Officer";

    private IReadOnlyList<InteractionLog> OrderedInteractions => Interactions
        .OrderByDescending(interaction => interaction.InteractionDate)
        .ThenByDescending(interaction => interaction.CreatedAt)
        .ToList();

    private async Task OpenEditDialogAsync(InteractionLog interaction)
    {
        var parameters = new DialogParameters
        {
            [nameof(LogInteraction.MemberId)] = interaction.MemberId,
            [nameof(LogInteraction.InteractionLogId)] = interaction.InteractionLogId,
            [nameof(LogInteraction.IsMemberLocked)] = LockMemberSelection
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<LogInteraction>("Edit Interaction", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await RefreshAsync(interaction.MemberId);
        }
    }

    private async Task ConfirmDeleteAsync(InteractionLog interaction)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Message)] = $"Delete the {interaction.InteractionType.ToLowerInvariant()} interaction from {interaction.InteractionDate:MMM dd, yyyy}?",
            [nameof(ConfirmDialog.ConfirmText)] = "Delete",
            [nameof(ConfirmDialog.ConfirmColor)] = Color.Error
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Interaction", parameters, options);
        var result = await dialog.Result;
        if (result?.Canceled != false)
        {
            return;
        }

        await InteractionService.DeleteInteractionAsync(interaction.InteractionLogId);
        Snackbar.Add("Interaction deleted.", Severity.Success);
        await RefreshAsync(interaction.MemberId);
    }

    private async Task RefreshAsync(int memberId)
    {
        if (OnChanged.HasDelegate)
        {
            await OnChanged.InvokeAsync();
            return;
        }

        Interactions = await InteractionService.GetByMemberAsync(memberId);
        StateHasChanged();
    }

    private static string GetInteractionIcon(string interactionType)
        => interactionType switch
        {
            "Call" => Icons.Material.Filled.Call,
            "Meeting" => Icons.Material.Filled.Handshake,
            "Follow-up" => Icons.Material.Filled.Replay,
            "Message" => Icons.Material.Filled.Message,
            "Visit" => Icons.Material.Filled.LocationOn,
            _ => Icons.Material.Filled.Forum
        };

    private static Color GetInteractionColor(string interactionType)
        => interactionType switch
        {
            "Call" => Color.Info,
            "Meeting" => Color.Success,
            "Follow-up" => Color.Warning,
            "Message" => Color.Primary,
            "Visit" => Color.Secondary,
            _ => Color.Default
        };
}
