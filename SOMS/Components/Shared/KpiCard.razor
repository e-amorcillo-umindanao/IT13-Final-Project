<MudCard Class="kpi-card dashboard-kpi-shell" Style="padding: 20px; height: 100%; border: 1px solid #E2E8F0; border-radius: 4px; box-shadow: none;">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icon" Size="Size.Medium" Color="@Color" />
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Title</MudText>
        </MudStack>

        <MudText Typo="Typo.h5" Style="font-weight: 700; color: #0F172A;">@Value</MudText>
    </MudStack>
</MudCard>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string Icon { get; set; } = string.Empty;

    [Parameter]
    public Color Color { get; set; } = Color.Primary;
}
