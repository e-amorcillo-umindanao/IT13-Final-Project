@inject AuthService authService

<div class="soms-sidebar">
    <div class="soms-sidebar-brand">
        <MudText Typo="Typo.body1" Class="fw-bold" Style="color: white; font-size: 15px;">SOMS</MudText>
        <MudText Typo="Typo.caption" Style="color: #94A3B8; font-size: 12px;">University of Mindanao</MudText>
    </div>

    <MudNavMenu Class="soms-sidebar-menu">
        <MudNavLink Href="/dashboard" Match="NavLinkMatch.Prefix" ActiveClass="active" Class="soms-sidebar-link" Icon="@Icons.Material.Filled.Dashboard">
            Dashboard
        </MudNavLink>
        <MudNavLink Href="/members" Match="NavLinkMatch.Prefix" ActiveClass="active" Class="soms-sidebar-link" Icon="@Icons.Material.Filled.Group">
            Members
        </MudNavLink>
        <MudNavLink Href="/engagement" Match="NavLinkMatch.Prefix" ActiveClass="active" Class="soms-sidebar-link" Icon="@Icons.Material.Filled.Forum">
            Engagement
        </MudNavLink>
        <MudNavLink Href="/events" Match="NavLinkMatch.Prefix" ActiveClass="active" Class="soms-sidebar-link" Icon="@Icons.Material.Filled.Event">
            Events
        </MudNavLink>
        <MudNavLink Href="/documents" Match="NavLinkMatch.Prefix" ActiveClass="active" Class="soms-sidebar-link" Icon="@Icons.Material.Filled.Description">
            Documents
        </MudNavLink>
        <MudNavLink Href="/reports" Match="NavLinkMatch.Prefix" ActiveClass="active" Class="soms-sidebar-link" Icon="@Icons.Material.Filled.Assessment">
            Reports
        </MudNavLink>

        @if (authService.CurrentRole == "Admin")
        {
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
                Settings
            </MudNavLink>
        }
    </MudNavMenu>
</div>
