@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject AuthService AuthService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

@if (AuthService.IsAuthenticated)
{
    <MudLayout @onmousemove="HandleUserActivity"
               @onmousedown="HandleUserActivity"
               @onkeydown="HandleUserActivity"
               tabindex="0">
        <TopBar />
        <MudDrawer Open="true"
                   Variant="DrawerVariant.Persistent"
                   Anchor="Anchor.Start"
                   Elevation="0"
                   ClipMode="DrawerClipMode.Always">
            <Sidebar />
        </MudDrawer>
        <MudMainContent Class="soms-main-content">
            <div class="soms-content-frame">
                @Body
            </div>
        </MudMainContent>
    </MudLayout>

    <MudOverlay Visible="@AuthService.IsSessionLocked"
                DarkBackground="true"
                ZIndex="9999"
                LockScroll="true"
                AutoClose="false"
                Class="session-lock-overlay">
        <div class="session-lock-shell">
            <MudCard Class="session-lock-card" Elevation="0" Style="border: 1px solid #E2E8F0; border-radius: 4px; max-width: 420px; width: 100%;">
                <MudCardContent Class="pa-6">
                    <MudStack Spacing="3">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large">
                                <MudIcon Icon="@Icons.Material.Filled.Lock" />
                            </MudAvatar>
                            <MudText Typo="Typo.h5" Align="Align.Center">Session Locked</MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                                Re-enter the password for @AuthService.CurrentUser?.Username to continue.
                            </MudText>
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(_unlockErrorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                                @_unlockErrorMessage
                            </MudAlert>
                        }

                        <MudTextField T="string"
                                      Label="Password"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      InputType="InputType.Password"
                                      Disabled="_isUnlocking"
                                      @bind-Value="_unlockPassword" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="_isUnlocking"
                                   OnClick="UnlockAsync">
                            @if (_isUnlocking)
                            {
                                <MudProgressCircular Class="me-2" Indeterminate="true" Size="Size.Small" Color="Color.Inherit" />
                                <span>Unlocking...</span>
                            }
                            else
                            {
                                <span>Unlock</span>
                            }
                        </MudButton>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Disabled="_isUnlocking"
                                   OnClick="LogoutInstead">
                            Log Out Instead
                        </MudButton>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </div>
    </MudOverlay>
}

@code {
    private CancellationTokenSource? _sessionCancellationTokenSource;
    private DotNetObjectReference<MainLayout>? _dotNetReference;
    private string _unlockPassword = string.Empty;
    private string? _unlockErrorMessage;
    private bool _isUnlocking;
    private bool _isDisposed;

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            NavManager.NavigateTo("/login");
            return;
        }

        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !AuthService.IsAuthenticated)
        {
            return;
        }

        _sessionCancellationTokenSource = new CancellationTokenSource();
        _dotNetReference = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("somsActivityTracker.start", _dotNetReference);
        _ = MonitorSessionAsync(_sessionCancellationTokenSource.Token);
    }

    private Task HandleUserActivity()
    {
        if (!AuthService.IsSessionLocked)
        {
            AuthService.RecordActivity();
        }

        return Task.CompletedTask;
    }

    [JSInvokable]
    public void NotifyUserActivity()
    {
        if (!AuthService.IsSessionLocked)
        {
            AuthService.RecordActivity();
        }
    }

    private async Task MonitorSessionAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(60));

            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (!AuthService.IsSessionExpired())
                {
                    continue;
                }

                await InvokeAsync(() =>
                {
                    _unlockPassword = string.Empty;
                    _unlockErrorMessage = null;
                    AuthService.LockSession();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task UnlockAsync()
    {
        if (_isUnlocking)
        {
            return;
        }

        _isUnlocking = true;
        _unlockErrorMessage = null;

        try
        {
            var isUnlocked = await AuthService.UnlockSessionAsync(_unlockPassword);
            if (!isUnlocked)
            {
                _unlockErrorMessage = "Incorrect password";
                return;
            }

            _unlockPassword = string.Empty;
            _unlockErrorMessage = null;
        }
        finally
        {
            _isUnlocking = false;
        }
    }

    private void LogoutInstead()
    {
        AuthService.Logout();
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    private void HandleAuthStateChanged()
    {
        if (_isDisposed)
        {
            return;
        }

        if (!AuthService.IsAuthenticated)
        {
            _unlockPassword = string.Empty;
            _unlockErrorMessage = null;
            _ = InvokeAsync(() => NavManager.NavigateTo("/login", forceLoad: true));
            return;
        }

        if (!AuthService.IsSessionLocked)
        {
            _unlockPassword = string.Empty;
            _unlockErrorMessage = null;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;

        _sessionCancellationTokenSource?.Cancel();
        _sessionCancellationTokenSource?.Dispose();
        _dotNetReference?.Dispose();

        try
        {
            await JSRuntime.InvokeVoidAsync("somsActivityTracker.stop");
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
