@inject NavigationManager NavManager
@inject AuthService AuthService
@implements IDisposable

<Router AppAssembly="@typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        @if (ShouldRedirectToLogin)
        {
            <RedirectTo Route="/login" />
        }
        else if (ShouldRedirectToDashboard)
        {
            <RedirectTo Route="/dashboard" />
        }
        else
        {
            <RouteView RouteData="@routeData" DefaultLayout="@GetLayoutType()" />
            <FocusOnNavigate RouteData="@routeData" Selector="[data-page-title]" />
        }
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(AuthLayout)">
            <MudText>Page not found. <a href="/login">Go to Login</a></MudText>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private bool _isDisposed;

    private string CurrentRoute
    {
        get
        {
            var relativePath = NavManager.ToBaseRelativePath(NavManager.Uri).Trim('/');
            return string.IsNullOrWhiteSpace(relativePath) ? "/" : $"/{relativePath}";
        }
    }

    private bool IsLoginRoute => string.Equals(CurrentRoute, "/login", StringComparison.OrdinalIgnoreCase);
    private bool IsRootRoute => string.Equals(CurrentRoute, "/", StringComparison.OrdinalIgnoreCase);
    private bool ShouldRedirectToLogin => !AuthService.IsAuthenticated && !IsLoginRoute;
    private bool ShouldRedirectToDashboard => AuthService.IsAuthenticated && IsLoginRoute;

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        EnforceAuthRedirect();
    }

    private Type GetLayoutType() => IsLoginRoute ? typeof(AuthLayout) : typeof(MainLayout);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        EnforceAuthRedirect();
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleAuthStateChanged()
    {
        EnforceAuthRedirect();
        _ = InvokeAsync(StateHasChanged);
    }

    private void EnforceAuthRedirect()
    {
        if (_isDisposed)
        {
            return;
        }

        if (IsRootRoute)
        {
            NavManager.NavigateTo("/login", forceLoad: false);
            return;
        }

        if (!AuthService.IsAuthenticated && !IsLoginRoute)
        {
            NavManager.NavigateTo("/login", forceLoad: false);
            return;
        }

        if (AuthService.IsAuthenticated && IsLoginRoute)
        {
            NavManager.NavigateTo("/dashboard", forceLoad: false);
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        NavManager.LocationChanged -= OnLocationChanged;
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
    }
}
